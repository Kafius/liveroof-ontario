---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Portfolio – LiveRoof Green Roof Systems">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Portfolio"
    title="Project"
    highlight="Portfolio"
    subtitle="Thousands of green roofs installed across North America — from university campuses to corporate headquarters."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Portfolio' },
    ]}
  />

  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="max-w-[600px] mx-auto text-center">
        <div class="w-16 h-16 rounded-2xl bg-green-light flex items-center justify-center mx-auto mb-6">
          <svg width="32" height="32" fill="none" stroke="#00B25A" stroke-width="1.5" viewBox="0 0 24 24">
            <rect x="3" y="3" width="18" height="18" rx="3" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
          </svg>
        </div>
        <h2 class="font-serif text-[2rem] text-dark mb-4">Browse All Projects</h2>
        <p class="text-text-muted leading-relaxed mb-8">
          Search and explore the full LiveRoof project gallery — filter by size, location, and building type
          to find inspiration for your next green roof.
        </p>
        <a href="https://liveroof.com/projects/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          View Project Gallery on LiveRoof.com &rarr;
        </a>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
