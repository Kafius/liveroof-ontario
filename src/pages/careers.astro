---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';

const perks = [
  {
    category: 'Continual Growth',
    color: 'green',
    items: [
      'Detailed training programs',
      'Effective management & mentorship',
      'Interesting work variety',
      'Job matching to your strengths',
      'Work with a market leader',
      'Regular performance reviews',
    ],
  },
  {
    category: 'Culture',
    color: 'blue',
    items: [
      'Environmental focus & mission-driven',
      'Friendly, supportive staff',
      'Pride in our products',
      'Casual dress code',
      'Professionalism & respect',
      'Team atmosphere & rapid innovation',
    ],
  },
  {
    category: 'Competitive Compensation',
    color: 'green',
    items: [
      'Performance-based pay',
      '401(k) with employer matching',
      'Paid time off',
      'Medical insurance with HSA',
      'Dental & disability insurance',
      'Employee assistance & referral bonuses',
    ],
  },
];

const departments = [
  'Accounting',
  'Administrative Office',
  'Designers & Estimators',
  'Growers (Horticulture)',
  'Human Resources',
  'Information Technology',
  'Maintenance',
  'Management',
  'Production & Shipping',
  'Sales',
  'Shipping & Logistics',
  'Supervisors',
];
---

<Layout title="Careers – LiveRoof Ontario">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Careers"
    title="Join Our"
    highlight="Team"
    subtitle="We're passionate about people, plants, and our planet. We aim to create a greener, healthier, and more sustainable world."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Careers' },
    ]}
  />

  <!-- Intro -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div>
          <span class="tag">Work With Us</span>
          <h2 class="font-serif text-[2.2rem] leading-[1.18] text-dark mb-5">
            Grow Your Career with LiveRoof Ontario
          </h2>
          <p class="text-text-muted leading-relaxed mb-4">
            Thank you for your interest in employment with LiveRoof Ontario, a division of Hillen Nursery, Inc.
            — a family-owned operation since 1983. We're passionate about people, plants, and our planet.
          </p>
          <p class="text-text-muted leading-relaxed">
            Located in Mount Brydges, Ontario, we grow and ship fully mature, vegetated LiveRoof modules
            across Ontario and the Atlantic provinces. Join a team that's making cities greener, one roof at a time.
          </p>
        </div>
        <div class="photo-placeholder rounded-xl aspect-[4/3]">
          <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <rect x="3" y="3" width="18" height="18" rx="3" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
          </svg>
          <span>Our Team</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Perks -->
  <section class="py-14 md:py-24 bg-mid">
    <div class="container">
      <div class="section-header">
        <span class="tag">Why Join Us</span>
        <h2>What We Offer</h2>
        <p>A workplace that invests in your growth, values culture, and rewards performance.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {perks.map((perk) => (
          <div class="bg-white rounded-xl p-8 shadow-[0_2px_20px_rgba(35,31,32,0.06)]">
            <div class={`w-12 h-12 rounded-lg flex items-center justify-center mb-5 ${perk.color === 'green' ? 'bg-green-light' : 'bg-blue-light'}`}>
              <svg width="24" height="24" fill="none" stroke={perk.color === 'green' ? '#17b060' : '#0092CF'} stroke-width="2" viewBox="0 0 24 24">
                <path d="M9 12l2 2 4-4" />
                <circle cx="12" cy="12" r="10" />
              </svg>
            </div>
            <h3 class="font-serif text-[1.25rem] text-dark mb-4">{perk.category}</h3>
            <ul class="space-y-3">
              {perk.items.map((item) => (
                <li class="flex items-start gap-3">
                  <svg class={`flex-shrink-0 mt-1 ${perk.color === 'green' ? 'text-green' : 'text-blue'}`} width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-[0.88rem] text-text-muted">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Departments -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="section-header">
        <span class="tag">Departments</span>
        <h2>Areas of Opportunity</h2>
        <p>We hire across a wide range of departments. Don't see a current opening? Apply anyway — we keep applications on file.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {departments.map((dept) => (
          <div class="bg-mid rounded-xl px-5 py-4 text-center">
            <span class="text-[0.9rem] font-semibold text-dark">{dept}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Application Form -->
  <section class="py-14 md:py-24 bg-mid" id="apply">
    <div class="container">
      <div class="max-w-[640px] mx-auto">
        <div class="text-center mb-12">
          <span class="tag">Apply Now</span>
          <h2 class="font-serif text-[2.2rem] text-dark mb-4">Submit Your Application</h2>
          <p class="text-text-muted leading-relaxed">
            Interested in joining our team? Fill out the form below and upload your resume.
            We'll be in touch if there's a good fit.
          </p>
        </div>

        <form class="bg-white rounded-xl p-8 shadow-[0_2px_20px_rgba(35,31,32,0.06)]" action="#" method="POST" enctype="multipart/form-data">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="firstName" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">First Name *</label>
              <input
                type="text"
                id="firstName"
                name="firstName"
                required
                class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
              />
            </div>
            <div>
              <label for="lastName" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Last Name *</label>
              <input
                type="text"
                id="lastName"
                name="lastName"
                required
                class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
              />
            </div>
          </div>

          <div class="mb-5">
            <label for="email" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Email Address *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
            />
          </div>

          <div class="mb-5">
            <label for="phone" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Phone Number</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
            />
          </div>

          <div class="mb-5">
            <label for="department" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Department of Interest</label>
            <select
              id="department"
              name="department"
              class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
            >
              <option value="">Select a department</option>
              {departments.map((dept) => (
                <option value={dept}>{dept}</option>
              ))}
            </select>
          </div>

          <div class="mb-5">
            <label for="message" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Cover Letter / Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green resize-y"
            ></textarea>
          </div>

          <div class="mb-8">
            <label for="resume" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Resume Upload (PDF, DOC, DOCX — max 2MB)</label>
            <input
              type="file"
              id="resume"
              name="resume"
              accept=".pdf,.doc,.docx"
              class="w-full text-[0.88rem] text-text-muted file:mr-4 file:py-2.5 file:px-5 file:rounded-lg file:border-0 file:text-[0.82rem] file:font-semibold file:bg-green-light file:text-green file:cursor-pointer hover:file:bg-green hover:file:text-white file:transition-colors"
            />
          </div>

          <button type="submit" class="btn btn-primary w-full text-center">Submit Application</button>
        </form>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
