---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';

// Fetch RSS feed from liveroof.com at build time
let articles: { title: string; link: string; date: string; excerpt: string }[] = [];

try {
  const res = await fetch('https://liveroof.com/feed/');
  const xml = await res.text();

  // Parse <item> blocks from RSS XML
  const itemRegex = /<item>([\s\S]*?)<\/item>/g;
  let match;
  while ((match = itemRegex.exec(xml)) !== null) {
    const item = match[1];
    const title = item.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/)?.[1]
      ?? item.match(/<title>(.*?)<\/title>/)?.[1] ?? '';
    const link = item.match(/<link>(.*?)<\/link>/)?.[1] ?? '';
    const pubDate = item.match(/<pubDate>(.*?)<\/pubDate>/)?.[1] ?? '';
    const desc = item.match(/<description><!\[CDATA\[(.*?)\]\]><\/description>/s)?.[1]
      ?? item.match(/<description>(.*?)<\/description>/s)?.[1] ?? '';

    // Strip HTML tags from description for a clean excerpt
    const excerpt = desc.replace(/<[^>]*>/g, '').replace(/&#8230;/g, '...').replace(/&amp;/g, '&').trim().slice(0, 200);

    const date = pubDate
      ? new Date(pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
      : '';

    articles.push({ title, link, date, excerpt: excerpt ? excerpt + '...' : '' });
  }
} catch (e) {
  // If fetch fails at build time, show empty state
  articles = [];
}
---

<Layout title="News – LiveRoof Vegetative Roof Systems">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="News"
    title="Latest from"
    highlight="LiveRoof"
    subtitle="Research, case studies, and insights from the world's leading vegetative roof system."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'News' },
    ]}
  />

  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      {articles.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
          {articles.map((article) => (
            <a href={article.link} target="_blank" rel="noopener noreferrer" class="news-card group block">
              <div class="h-[200px] photo-placeholder">
                <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="3" />
                  <circle cx="8.5" cy="8.5" r="1.5" />
                  <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
                </svg>
                <span>Article Photo</span>
              </div>
              <div class="news-card-body p-6">
                <div class="news-date">{article.date}</div>
                <h4 class="group-hover:text-blue transition-colors">{article.title}</h4>
                {article.excerpt && <p>{article.excerpt}</p>}
                <span class="news-read">Read Article &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-text-muted">Unable to load articles. Visit <a href="https://liveroof.com/news/" target="_blank" rel="noopener noreferrer" class="text-blue hover:underline">liveroof.com/news</a> for the latest.</p>
        </div>
      )}
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
