---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
import PhoneReveal from '../components/PhoneReveal.astro';

const serviceAreas = [
  'Ontario',
  'New Brunswick',
  'Newfoundland & Labrador',
  'Nova Scotia',
  'Prince Edward Island',
];

---

<Layout title="Contact – LiveRoof Ontario">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Contact Us"
    title="Get In"
    highlight="Touch"
    subtitle="We're here to help with your vegetated roof project — from initial design through installation and ongoing support."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Contact' },
    ]}
  />

  <!-- Ontario Office Contact Form + Map -->
  <section class="py-12 md:py-16 bg-mid" id="contact-form">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-stretch">
        <!-- Form (left) -->
        <div>
          <span class="tag">Send Us a Message</span>
          <h2 class="font-serif text-[2rem] leading-[1.18] text-dark mb-3">
            Reach Our Ontario Office
          </h2>
          <p class="text-text-muted leading-relaxed mb-6">
            Have a project in Ontario or Atlantic Canada? Send a note and we'll get
            back to you within one business day.
          </p>

          <form
            class="bg-white rounded-xl p-6 sm:p-7 shadow-[0_2px_20px_rgba(35,31,32,0.06)]"
            action="https://formspree.io/f/your-form-id"
            method="POST"
          >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="contact-firstName" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">First Name *</label>
              <input
                type="text"
                id="contact-firstName"
                name="firstName"
                required
                autocomplete="given-name"
                class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
              />
            </div>
            <div>
              <label for="contact-lastName" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Last Name *</label>
              <input
                type="text"
                id="contact-lastName"
                name="lastName"
                required
                autocomplete="family-name"
                class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="contact-email" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Email Address *</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
              />
            </div>
            <div>
              <label for="contact-phone" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Phone Number</label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                autocomplete="tel"
                class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="contact-company" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Company / Organization</label>
              <input
                type="text"
                id="contact-company"
                name="company"
                autocomplete="organization"
                class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
              />
            </div>
            <div>
              <label for="contact-region" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Project Region</label>
              <select
                id="contact-region"
                name="region"
                class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
              >
                <option value="">Select a region</option>
                {serviceAreas.map((area) => (
                  <option value={area}>{area}</option>
                ))}
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <div class="mb-5">
            <label for="contact-inquiry" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Inquiry Type</label>
            <select
              id="contact-inquiry"
              name="inquiryType"
              class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green"
            >
              <option value="">Select an option</option>
              <option value="New Project Quote">New project quote</option>
              <option value="Design / Engineering">Design &amp; engineering</option>
              <option value="Installation">Installation</option>
              <option value="Maintenance">Maintenance</option>
              <option value="Plants & Soil">Plants &amp; soil</option>
              <option value="General Inquiry">General inquiry</option>
            </select>
          </div>

          <div class="mb-6">
            <label for="contact-message" class="block text-[0.75rem] font-semibold text-text-muted uppercase tracking-wider mb-2">Message *</label>
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              placeholder="Tell us about your project — building type, roof size, timeline, and any questions you have."
              class="w-full px-4 py-3 rounded-lg border border-border bg-mid text-dark text-[0.92rem] outline-none transition-colors focus:border-green focus:ring-1 focus:ring-green resize-y"
            ></textarea>
          </div>

          <!-- Honeypot anti-spam (hidden from users) -->
          <div style="position:absolute;left:-9999px" aria-hidden="true">
            <label for="contact-website">Website</label>
            <input type="text" id="contact-website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <button type="submit" class="btn btn-primary w-full text-center">Send Message</button>

            <p class="text-[0.75rem] text-text-muted text-center mt-4 leading-relaxed">
              By submitting, you agree to be contacted by LiveRoof Ontario regarding your inquiry.
              We never share your information.
            </p>
          </form>
        </div>

        <!-- Map (right) -->
        <div class="flex flex-col">
          <div class="bg-white rounded-xl overflow-hidden shadow-[0_2px_20px_rgba(35,31,32,0.06)] flex-1 flex flex-col">
            <div class="aspect-[4/3] lg:aspect-auto lg:flex-1 lg:min-h-[420px] bg-mid">
              <iframe
                title="LiveRoof Ontario office location map"
                src="https://maps.google.com/maps?q=23078+Adelaide+Road,+Mount+Brydges,+ON,+N0L+1W0&hl=en&z=14&output=embed"
                width="100%"
                height="100%"
                style="border:0;"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              ></iframe>
            </div>
            <div class="p-5 border-t border-border">
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-lg bg-green-light flex items-center justify-center flex-shrink-0">
                  <svg width="18" height="18" fill="none" stroke="#17b060" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="text-[0.7rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Visit Us</div>
                  <div class="text-dark font-semibold leading-snug">23078 Adelaide Road<br />Mt. Brydges, ON, N0L 1W0</div>
                  <a
                    href="https://maps.google.com/maps?daddr=23078+Adelaide+Road,+Mount+Brydges,+ON,+N0L+1W0"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 mt-2 text-[0.85rem] font-semibold text-green hover:text-green-hover transition-colors"
                  >
                    Get directions
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Representative Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8">
        <!-- Kees Govers card -->
        <div class="bg-white rounded-xl p-5 shadow-[0_2px_20px_rgba(35,31,32,0.06)]">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-lg bg-green-light flex items-center justify-center flex-shrink-0">
              <svg width="22" height="22" fill="none" stroke="#17b060" stroke-width="2" viewBox="0 0 24 24">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-[0.7rem] text-green font-semibold uppercase tracking-wider mb-0.5">Representative</div>
              <div class="text-dark font-semibold text-[1.05rem] mb-2">Kees Govers</div>
              <div class="space-y-1 text-[0.9rem]">
                <div class="flex items-center gap-2 text-dark">
                  <svg class="flex-shrink-0 text-green" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
                  <PhoneReveal number="5196715777" class="font-medium hover:text-green transition-colors" />
                </div>
                <div class="flex items-center gap-2 text-dark">
                  <svg class="flex-shrink-0 text-green" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
                  <a href="mailto:kees@liveroofontario.ca" class="font-medium hover:text-green transition-colors truncate">kees@liveroofontario.ca</a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Carlo Boecklin card -->
        <div class="bg-white rounded-xl p-5 shadow-[0_2px_20px_rgba(35,31,32,0.06)]">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-lg bg-green-light flex items-center justify-center flex-shrink-0">
              <svg width="22" height="22" fill="none" stroke="#17b060" stroke-width="2" viewBox="0 0 24 24">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-[0.7rem] text-green font-semibold uppercase tracking-wider mb-0.5">Technical Sales</div>
              <div class="text-dark font-semibold text-[1.05rem] mb-2">Carlo Boecklin</div>
              <div class="space-y-1 text-[0.9rem]">
                <div class="flex items-center gap-2 text-dark">
                  <svg class="flex-shrink-0 text-green" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
                  <PhoneReveal number="5196715133" class="font-medium hover:text-green transition-colors" />
                </div>
                <div class="flex items-center gap-2 text-dark">
                  <svg class="flex-shrink-0 text-green" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
                  <a href="mailto:carlo@liveroofontario.ca" class="font-medium hover:text-green transition-colors truncate">carlo@liveroofontario.ca</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Global Headquarters -->
  <section class="py-12 md:py-16 bg-white">
    <div class="container">
      <div class="max-w-[680px] mb-8">
        <span class="tag" style="color:#0092CF">Global Headquarters</span>
        <h2 class="font-serif text-[2rem] leading-[1.18] text-dark mb-3">LiveRoof Global, LLC</h2>
        <p class="text-text-muted leading-relaxed">
          For general inquiries, technical questions, or to be connected with the right
          representative for your region, contact LiveRoof Global headquarters.
        </p>
      </div>

      <div class="bg-mid rounded-xl p-6 sm:p-7 grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-lg bg-blue-light flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" fill="none" stroke="#0092CF" stroke-width="2" viewBox="0 0 24 24">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
          </div>
          <div>
            <div class="text-[0.7rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Company</div>
            <div class="text-dark font-semibold leading-snug">LiveRoof Global, LLC</div>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-lg bg-blue-light flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" fill="none" stroke="#0092CF" stroke-width="2" viewBox="0 0 24 24">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
          </div>
          <div class="min-w-0">
            <div class="text-[0.7rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Phone</div>
            <PhoneReveal number="18008751392" format="dash" class="text-dark font-semibold hover:text-blue transition-colors" />
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-lg bg-blue-light flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" fill="none" stroke="#0092CF" stroke-width="2" viewBox="0 0 24 24">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
          </div>
          <div>
            <div class="text-[0.7rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Address</div>
            <div class="text-dark font-semibold leading-snug">14109 Cleveland St<br />Nunica, MI 49448</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
