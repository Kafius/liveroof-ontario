---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';

const serviceAreas = [
  'Ontario',
  'New Brunswick',
  'Newfoundland & Labrador',
  'Nova Scotia',
  'Prince Edward Island',
];

---

<Layout title="Contact – LiveRoof Ontario">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Contact Us"
    title="Get In"
    highlight="Touch"
    subtitle="We're here to help with your green roof project — from initial design through installation and ongoing support."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Contact' },
    ]}
  />

  <!-- LiveRoof Ontario -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <!-- Info -->
        <div>
          <span class="tag">Your Local Representative</span>
          <h2 class="font-serif text-[2.2rem] leading-[1.18] text-dark mb-5">LiveRoof Ontario & LiveRoof Atlantic</h2>
          <p class="text-text-muted leading-relaxed mb-4">
            At LiveRoof Ontario, we are dedicated to providing premium, sustainable green roof solutions
            that blend innovation with environmental responsibility. With nearly two decades of experience
            in horticulture, we embrace both the challenges and rewards of green roofing.
          </p>
          <p class="text-text-muted leading-relaxed mb-8">
            Located 20 minutes west of London, Ontario, in Mount Brydges, we are a division of
            Hillen Nursery, Inc. — a family-owned operation since 1983. We grow and ship fully mature,
            vegetated LiveRoof modules across Ontario and extend our reach to Atlantic coastal provinces
            through local producer partnerships.
          </p>

          <!-- Contact Card -->
          <div class="bg-mid rounded-xl p-5 sm:p-8 mb-8">
            <h3 class="font-semibold text-dark text-lg mb-4">Contact Information</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-green-light flex items-center justify-center flex-shrink-0">
                  <svg width="20" height="20" fill="none" stroke="#00B25A" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                  </svg>
                </div>
                <div>
                  <div class="text-[0.72rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Representative</div>
                  <div class="text-dark font-semibold">Kees Govers</div>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-green-light flex items-center justify-center flex-shrink-0">
                  <svg width="20" height="20" fill="none" stroke="#00B25A" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                </div>
                <div>
                  <div class="text-[0.72rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Phone</div>
                  <a href="tel:5196715777" class="text-dark font-semibold hover:text-green transition-colors">(519) 671-5777</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-green-light flex items-center justify-center flex-shrink-0">
                  <svg width="20" height="20" fill="none" stroke="#00B25A" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="2" y="4" width="20" height="16" rx="2" />
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                  </svg>
                </div>
                <div>
                  <div class="text-[0.72rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Email</div>
                  <a href="mailto:kees@liveroofontario.ca" class="text-dark font-semibold hover:text-green transition-colors">kees@liveroofontario.ca</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-green-light flex items-center justify-center flex-shrink-0">
                  <svg width="20" height="20" fill="none" stroke="#00B25A" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                </div>
                <div>
                  <div class="text-[0.72rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Location</div>
                  <div class="text-dark font-semibold">23078 Adelaide Road<br />Mt. Brydges, ON, N0L 1W0</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Service Areas -->
          <h3 class="font-semibold text-dark mb-3">Service Areas</h3>
          <div class="flex flex-wrap gap-2">
            {serviceAreas.map((area) => (
              <span class="chip green">{area}</span>
            ))}
          </div>
        </div>

        <!-- Photo -->
        <div>
          <div class="photo-placeholder rounded-xl aspect-[4/3] mb-6">
            <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="3" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
            </svg>
            <span>LiveRoof Ontario</span>
          </div>
          <p class="text-sm text-text-muted italic">
            A division of Hillen Nursery, Inc. — growing and shipping fully mature, vegetated LiveRoof
            modules since 1983.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LiveRoof Global -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <div>
          <div class="photo-placeholder rounded-xl aspect-[4/3]">
            <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="3" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
            </svg>
            <span>LiveRoof Global HQ</span>
          </div>
        </div>

        <div>
          <span class="tag">Global Headquarters</span>
          <h2 class="font-serif text-[2.2rem] leading-[1.18] text-dark mb-5">LiveRoof Global, LLC</h2>
          <p class="text-text-muted leading-relaxed mb-8">
            For general inquiries, technical questions, or to be connected with the right representative
            for your region, contact LiveRoof Global headquarters. Our team is available to assist with
            design, financial, installation, maintenance, and product questions.
          </p>

          <div class="bg-mid rounded-xl p-5 sm:p-8">
            <h3 class="font-semibold text-dark text-lg mb-4">Headquarters Contact</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-blue-light flex items-center justify-center flex-shrink-0">
                  <svg width="20" height="20" fill="none" stroke="#0092CF" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                </div>
                <div>
                  <div class="text-[0.72rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Phone</div>
                  <a href="tel:18008751392" class="text-dark font-semibold hover:text-blue transition-colors">1-800-875-1392</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-blue-light flex items-center justify-center flex-shrink-0">
                  <svg width="20" height="20" fill="none" stroke="#0092CF" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                </div>
                <div>
                  <div class="text-[0.72rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Address</div>
                  <div class="text-dark font-semibold">LiveRoof LLC<br />14109 Cleveland St<br />Nunica, MI 49448</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
