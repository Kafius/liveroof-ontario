---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';
import { sanityClient, PROJECTS_QUERY } from '../../lib/sanity';
import type { SanityProject } from '../../lib/sanity';

export async function getStaticPaths() {
  const projects: SanityProject[] = await sanityClient.fetch(PROJECTS_QUERY);
  return projects
    .filter(p => p.active !== false)
    .map(project => ({
      params: { slug: project.slug.current },
      props: { project },
    }));
}

const { project } = Astro.props as { project: SanityProject };

const provinceLabels: Record<string, string> = {
  ON: 'Ontario',
  NB: 'New Brunswick',
  NL: 'Newfoundland & Labrador',
  NS: 'Nova Scotia',
  PE: 'Prince Edward Island',
};

const showcaseLabels: Record<string, string> = {
  commercial: 'Commercial',
  educational: 'Educational',
  healthcare: 'Healthcare',
  'other-institutional': 'Other Institutional',
  public: 'Public',
  residential: 'Residential',
};

const moduleLabels: Record<string, string> = {
  deep: 'LiveRoof Deep System',
  lite: 'LiveRoof Lite System',
  maxx: 'LiveRoof Maxx System',
  standard: 'LiveRoof Standard System',
};

const leedLabels: Record<string, string> = {
  certified: 'LEED Certified',
  silver: 'LEED Silver',
  gold: 'LEED Gold',
  platinum: 'LEED Platinum',
};

const optionLabels: Record<string, string> = {
  'multiple-plant-mixes': 'Multiple Plant Mixes',
  'organic-shape': 'Organic Shape Design',
  'roofstone-pavers': 'RoofStone Pavers',
  'sloped-roof': 'Sloped Roof',
};

const location = [project.city, provinceLabels[project.province]].filter(Boolean).join(', ');
const heroPhoto = project.photos?.find(p => p.isMain) ?? project.photos?.[0];
const galleryPhotos = project.photos?.filter(p => p !== heroPhoto) ?? [];
---

<Layout title={`${project.name} – LiveRoof Ontario`}>
  <TopBar />
  <Header />

  {/* ── Hero ── */}
  <section class="relative py-16 md:py-24 overflow-hidden bg-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-80 to-blue/20"></div>
    <div class="absolute top-[-80px] right-[-80px] w-[400px] h-[400px] rounded-full bg-green/10"></div>
    <div class="absolute bottom-[-60px] left-[-40px] w-[280px] h-[280px] rounded-full bg-blue/10"></div>

    <div class="container relative z-10">
      <nav class="text-xs text-white/40 mb-8 tracking-wide">
        <a href="/" class="hover:text-green transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/portfolio" class="hover:text-green transition-colors">Portfolio</a>
        <span class="mx-2">/</span>
        <span class="text-white/70">{project.name}</span>
      </nav>

      <div class="max-w-[820px]">
        <div class="hero-eyebrow">{location || 'Project'}</div>
        <h1 class="font-serif text-[clamp(2rem,4vw,3.2rem)] text-white leading-[1.1] mb-6">
          {project.name}
        </h1>

        <div class="flex flex-wrap gap-1.5">
          {project.showcaseType && (
            <span class="chip dark text-[0.7rem]">{showcaseLabels[project.showcaseType]}</span>
          )}
          {project.moduleType && (
            <span class="chip blue text-[0.7rem]">{moduleLabels[project.moduleType]}</span>
          )}
          {project.leedCertified && (
            <span class="chip green text-[0.7rem]">{leedLabels[project.leedCertified]}</span>
          )}
          {project.roofBlue && (
            <span class="chip blue text-[0.7rem]">RoofBlue</span>
          )}
          {project.solaGreen && (
            <span class="chip green text-[0.7rem]">SolaGreen</span>
          )}
          {project.retrofit && (
            <span class="chip dark text-[0.7rem]">Retrofit</span>
          )}
          {project.publicAccess && (
            <span class="chip green text-[0.7rem]">Public Access</span>
          )}
        </div>
      </div>
    </div>
  </section>

  {/* ── Main content ── */}
  <section class="py-14 md:py-20 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-10 lg:gap-14">

        {/* Left: Photos + description */}
        <div class="space-y-8">

          {/* Hero photo */}
          <div class="aspect-[16/10] bg-mid rounded-2xl overflow-hidden">
            {heroPhoto?.image?.asset?.url ? (
              <img
                src={heroPhoto.image.asset.url + '?w=1280&h=800&fit=crop&auto=format'}
                alt={heroPhoto.caption ?? project.name}
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="photo-placeholder h-full rounded-none">
                <svg width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="3" />
                  <circle cx="8.5" cy="8.5" r="1.5" />
                  <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
                </svg>
                <span>Photos coming soon</span>
              </div>
            )}
          </div>

          {/* Description */}
          {project.description && (
            <div class="prose max-w-none">
              <h2 class="font-serif text-[1.6rem] text-dark mb-4">About this project</h2>
              <p class="text-text-muted leading-relaxed text-[1rem] whitespace-pre-line">{project.description}</p>
            </div>
          )}

          {/* Gallery */}
          {galleryPhotos.length > 0 && (
            <div>
              <h2 class="font-serif text-[1.6rem] text-dark mb-4">Gallery</h2>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                {galleryPhotos.map(photo => (
                  photo.image?.asset?.url && (
                    <div class="aspect-square bg-mid rounded-lg overflow-hidden">
                      <img
                        src={photo.image.asset.url + '?w=480&h=480&fit=crop&auto=format'}
                        alt={photo.caption ?? project.name}
                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    </div>
                  )
                ))}
              </div>
            </div>
          )}
        </div>

        {/* Right: Sidebar */}
        <aside class="lg:sticky lg:top-24 self-start space-y-6">
          <div class="bg-mid rounded-2xl p-6 space-y-5">
            <h3 class="font-serif text-[1.2rem] text-dark">Project details</h3>

            <dl class="space-y-4 text-[0.9rem]">
              {location && (
                <div>
                  <dt class="text-text-muted font-semibold uppercase tracking-wide text-[0.7rem] mb-0.5">Location</dt>
                  <dd class="text-dark">{location}</dd>
                </div>
              )}

              {project.projectSize && (
                <div>
                  <dt class="text-text-muted font-semibold uppercase tracking-wide text-[0.7rem] mb-0.5">Size</dt>
                  <dd class="text-dark">{project.projectSize.toLocaleString()} sq m</dd>
                </div>
              )}

              {project.installationDate && (
                <div>
                  <dt class="text-text-muted font-semibold uppercase tracking-wide text-[0.7rem] mb-0.5">Installed</dt>
                  <dd class="text-dark">
                    {new Date(project.installationDate).toLocaleDateString('en-CA', { year: 'numeric', month: 'long' })}
                  </dd>
                </div>
              )}

              {project.grower && (
                <div>
                  <dt class="text-text-muted font-semibold uppercase tracking-wide text-[0.7rem] mb-0.5">Grower</dt>
                  <dd class="text-dark">{project.grower}</dd>
                </div>
              )}

              {project.moduleType && (
                <div>
                  <dt class="text-text-muted font-semibold uppercase tracking-wide text-[0.7rem] mb-0.5">System</dt>
                  <dd class="text-dark">{moduleLabels[project.moduleType]}</dd>
                </div>
              )}

              {project.showcaseType && (
                <div>
                  <dt class="text-text-muted font-semibold uppercase tracking-wide text-[0.7rem] mb-0.5">Type</dt>
                  <dd class="text-dark">{showcaseLabels[project.showcaseType]}</dd>
                </div>
              )}
            </dl>

            {project.options && project.options.length > 0 && (
              <div class="pt-4 border-t border-border">
                <dt class="text-text-muted font-semibold uppercase tracking-wide text-[0.7rem] mb-2">Features</dt>
                <ul class="flex flex-wrap gap-1.5">
                  {project.options.map(opt => (
                    <li class="text-[0.72rem] text-dark bg-white border border-border rounded-full px-2.5 py-0.5">
                      {optionLabels[opt] ?? opt}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>

          <a href="/portfolio" class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold text-green hover:gap-2.5 transition-all">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Back to all projects
          </a>
        </aside>

      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
