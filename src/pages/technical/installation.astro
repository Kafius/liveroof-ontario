---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const guides = [
  {
    title: 'LiveRoof Installation',
    description: 'Follow these simple instructions for successful, efficient green roof installations.',
    hasGuide: true,
  },
  {
    title: 'Continuous Flow for Optimizing Profitability',
    description: 'Practicing lean flow is essential to being competitive and profitable. Recommendations for enhancing installer profitability through continuous flow of materials, appropriate equipment, and proper team size.',
    hasGuide: false,
  },
  {
    title: 'RoofEdge Installation',
    description: 'RoofEdge is used in perimeter areas to protect modules from UV degradation and to contain soil. When stone ballast or traditional paver/pedestals are used, edging must be used.',
    hasGuide: true,
  },
  {
    title: 'RoofStone Installation',
    description: 'RoofStone installs TEN TIMES as fast as traditional roof pavers and pedestals. Ideal for fast, efficient installation of maintenance pathways, vegetation-free zones, and small patios.',
    hasGuide: true,
  },
  {
    title: 'RoofBlue Installation',
    description: 'RoofBlue risers provide void space beneath LiveRoof modules for additional stormwater detention. RoofBlue risers install simply and efficiently.',
    hasGuide: false,
  },
  {
    title: 'WindDisc Installation',
    description: 'The WindDisc system helps to secure LiveRoof brand green roof modules against wind uplift, improving the already strong resistance to uplift.',
    hasGuide: false,
  },
  {
    title: 'SolaGreen Installation',
    description: 'Harness the power of the sun and nature to reduce energy costs, enhance property value, manage stormwater, and contribute to a sustainable future.',
    hasGuide: false,
  },
];
---

<Layout title="Installation – LiveRoof Technical Resources">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Installation"
    title="Installation"
    highlight="Resources"
    subtitle="LiveRoof projects are installed only by LiveRoof Certified Installers trained in the proper method of installing LiveRoof systems."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Technical', href: '/technical' },
      { label: 'Installation' },
    ]}
  />

  <!-- Installer CTA -->
  <section class="py-12 bg-mid">
    <div class="container">
      <div class="bg-white rounded-xl p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-text-muted text-[0.92rem]">
          Looking for a LiveRoof Certified Installer? Bidding or installing your first green roof project?
        </p>
        <a href="/contact" class="btn btn-primary flex-shrink-0">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- Installation Guides -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid gap-12">
        {guides.map((guide, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${i % 2 === 1 ? 'lg:[direction:rtl]' : ''}`}>
            <!-- Video/Image Placeholder -->
            <div class="relative aspect-video bg-dark rounded-xl flex items-center justify-center">
              <div class="flex flex-col items-center gap-3 text-white/40">
                <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center">
                  <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
                <span class="text-[0.72rem] uppercase tracking-wider font-semibold">Video Placeholder</span>
              </div>
            </div>

            <div class={i % 2 === 1 ? 'lg:[direction:ltr]' : ''}>
              <h3 class="font-serif text-[1.5rem] text-dark mb-3">{guide.title}</h3>
              <p class="text-text-muted leading-relaxed mb-4">{guide.description}</p>
              {guide.hasGuide && (
                <a href="#" class="benefit-link">
                  Download Installation Guide (PDF)
                  <span>&rarr;</span>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
