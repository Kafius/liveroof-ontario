---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const sections = [
  {
    title: 'Fire Safety',
    text: 'LiveRoof conducted UL Labs testing in January 2008 on Sedum-populated modules. The system was exposed to direct flame for 10 minutes on a plywood deck — resulting in no ignition of the plywood deck and no spread of flame via the plant material. In July 2011, LiveRoof Hybrid became the first green roof system to receive FM Approval per FM Standard 4477.',
  },
  {
    title: 'Irrigation Design',
    text: 'During cooling seasons, irrigated green roofs can reduce room temperatures 16–27°F compared to non-irrigated systems. Overhead matched-precipitation rotor systems perform best — a 2011 MSU study showed overhead irrigation retained more water with less waste than sub-irrigation and drip systems. LiveRoof developed PipeRunner to simplify irrigation line placement.',
  },
  {
    title: 'Job Site Safety',
    text: 'High winds can occur anytime during installation — materials require appropriate temporary ballast coverage. Designers should plan maintenance pathways and landing areas using RoofStone pavers for regular foot traffic zones. Green roofs without adequate perimeter railings should include permanent tie-off points for maintenance personnel.',
  },
  {
    title: 'Plant Design',
    text: 'Extensive green roof systems (under 6" soil depth) require plants exceptional at drought resistance. LiveRoof uses Sedums, Alliums, Sempervivums, Euphorbias, and Delospermas — plants exhibiting Crassulacean Acid Metabolism (CAM) that open leaf pores at night to minimize water loss. Base plants create living mulch while accent plants add color and visual interest.',
  },
  {
    title: 'Roof Membranes',
    text: 'LiveRoof is compatible with nearly all waterproofing types. For conventional membrane roofs, specify minimum 1mm (40 mil) slip sheets with overlapped, bonded seams. Compatible types include TPO, PVC, Polypropylene, HDPE (welded seam) and EPDM (glued seam). Never use duct tape or moisture-holding fabrics as slip sheets.',
  },
  {
    title: 'Stormwater Management',
    text: 'Annual runoff reduction ranges from 60–100% based on regional precipitation, rainfall intensity, wind and sun exposure, roof slope, soil depth, and plant characteristics. Research found 4-inch soil depth performed optimally for stormwater retention. Greater slopes reduce water retention — from approximately 85% at 2% slope to 76% at 25% slope.',
  },
  {
    title: 'Sloped Roofs',
    text: 'Green roofs should not be applied to roofs with slope greater than 40 degrees per German FLL and GRHC guidelines. A minimum of ¼"/12\' slope is needed for adequate drainage. Sloped green roofs create downward forces against parapets — LiveRoof provides force loading tables for all module sizes.',
  },
  {
    title: 'Wind Resistance',
    text: 'LiveRoof modules populated with hardy Sedums were tested with winds exceeding 110 MPH for 1 hour 50 minutes — no loss of growing medium and all plants remained intact. Negative pressure (uplift) forces are greatest in roof corners, secondary along parapet walls, and lowest in the field. WindDisc connectors provide a sustained 200 PSF rating.',
  },
];

const weights = [
  { system: 'LiveRoof Lite', weight: '~15–17 lbs/sq ft' },
  { system: 'LiveRoof Standard', weight: '~27–29 lbs/sq ft' },
  { system: 'LiveRoof Deep', weight: '~40–50 lbs/sq ft' },
  { system: 'LiveRoof Maxx', weight: '~60–65 lbs/sq ft' },
];
---

<Layout title="Design & Engineering – LiveRoof Technical Resources">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Design & Engineering"
    title="Design &"
    highlight="Engineering"
    subtitle="Comprehensive design resources for architects, landscape architects, and engineers planning green roof projects."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Technical', href: '/technical' },
      { label: 'Design & Engineering' },
    ]}
  />

  <!-- Sections -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid gap-10 lg:gap-16">
        {sections.map((s, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${i % 2 === 1 ? 'lg:[direction:rtl]' : ''}`}>
            <div class="photo-placeholder rounded-xl aspect-[16/10]">
              <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <rect x="3" y="3" width="18" height="18" rx="3" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
              </svg>
              <span>{s.title}</span>
            </div>
            <div class={i % 2 === 1 ? 'lg:[direction:ltr]' : ''}>
              <span class="tag">0{i + 1}</span>
              <h2 class="font-serif text-[1.8rem] text-dark mb-4">{s.title}</h2>
              <p class="text-text-muted leading-relaxed">{s.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Saturated Weights -->
  <section class="py-10 md:py-16 bg-mid">
    <div class="container">
      <div class="section-header">
        <span class="tag">Reference</span>
        <h2>Module Saturated Weights</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-[700px] mx-auto">
        {weights.map((w) => (
          <div class="bg-white rounded-xl p-5 text-center shadow-[0_2px_12px_rgba(35,31,32,0.04)]">
            <div class="text-[0.72rem] text-text-muted uppercase tracking-wider font-semibold mb-2">{w.system}</div>
            <div class="font-semibold text-dark">{w.weight}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
