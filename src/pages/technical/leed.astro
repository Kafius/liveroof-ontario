---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const credits = [
  {
    category: 'Sustainable Sites',
    color: 'green',
    items: [
      { credit: 'Site Development — Protect or Restore Habitat', desc: 'Reclaims vegetation where buildings exist, provides habitat for songbirds, butterflies, and invertebrate species.' },
      { credit: 'Open Space', desc: 'Green roofs count toward open space requirements, promoting biodiversity on otherwise impermeable surfaces.' },
      { credit: 'Rainwater Management', desc: 'Reduces excess stormwater discharge through evapotranspiration and infiltration. Filters and detoxifies stormwater.' },
      { credit: 'Heat Island Reduction', desc: 'Reduces roof temperatures during summer months. Equivalent to high-reflectance roofs in LEEDv4 projects.' },
    ],
  },
  {
    category: 'Water Efficiency',
    color: 'blue',
    items: [
      { credit: 'Outdoor Water Use Reduction', desc: 'When vegetated with drought-resistant LiveRoof plants, installations require little irrigation — less than 50% of typical compared to conventional plant material.' },
    ],
  },
  {
    category: 'Energy & Atmosphere',
    color: 'green',
    items: [
      { credit: 'Optimize Energy Performance', desc: 'Anticipated air conditioning savings exceeding 25% on single-story structures in northern temperate zones. Winter R-value of approximately 1.9 for the standard system.' },
    ],
  },
  {
    category: 'Materials & Resources',
    color: 'blue',
    items: [
      { credit: 'Construction & Demolition Waste Management', desc: 'Modules delivered on reusable Hoppit racks — no pallet/cardboard disposal. Soil elevators recyclable through LiveRoof growers.' },
      { credit: 'Building Life-Cycle Impact Reduction', desc: 'Green roofs extend membrane life by 200–300%, significantly reducing life-cycle environmental impact.' },
      { credit: 'Sourcing of Raw Materials', desc: 'LiveRoof modules are composed of 100% recycled polypropylene (avg. 10% post-consumer, 90% post-industrial). Manufactured across US and Canada.' },
      { credit: 'Material Ingredients', desc: 'Plants harvested without soil disturbance or replanting needs, reducing carbon and fertilizer inputs. Rapidly renewable materials.' },
    ],
  },
  {
    category: 'Innovation in Design',
    color: 'green',
    items: [
      { credit: 'Innovation Credits', desc: 'Potential applications include improved workplace productivity, outdoor meeting spaces, herb/vegetable cultivation, beekeeping, sound reduction, carbon sequestration, wildlife-friendly design, and eco-roof monitoring.' },
    ],
  },
];

const certifiedProjects = [
  { name: 'Zurich North America HQ', level: 'Platinum' },
  { name: 'Van Andel Institute Expansion', level: 'Platinum' },
  { name: 'WMS Gaming HQ', level: 'Platinum' },
  { name: 'Aurora Sinai Hospital', level: 'Gold' },
  { name: 'Mariano Azuela Elementary', level: 'Gold' },
  { name: 'GVSU Boat House', level: 'Gold' },
  { name: 'Monroe Clinic Hospital', level: 'Silver' },
];
---

<Layout title="LEED Resources – LiveRoof Technical Resources">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="LEED"
    title="LEED"
    highlight="Resources"
    subtitle="How LiveRoof green roof systems contribute to LEED certification across multiple credit categories."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Technical', href: '/technical' },
      { label: 'LEED' },
    ]}
  />

  <!-- Definition -->
  <section class="py-12 bg-mid">
    <div class="container">
      <div class="max-w-[760px] mx-auto text-center">
        <p class="text-text-muted leading-relaxed">
          <strong class="text-dark">LEED</strong> (Leadership in Energy and Environmental Design) is a green building
          rating system developed by the U.S. Green Building Council (USGBC).
        </p>
      </div>
    </div>
  </section>

  <!-- Credit Categories -->
  {credits.map((section, sIdx) => (
    <section class={`py-16 ${sIdx % 2 === 0 ? 'bg-white' : 'bg-mid'}`}>
      <div class="container">
        <div class="flex items-center gap-4 mb-8">
          <div class={`w-10 h-10 rounded-lg flex items-center justify-center ${section.color === 'green' ? 'bg-green-light' : 'bg-blue-light'}`}>
            <svg width="20" height="20" fill="none" stroke={section.color === 'green' ? '#00B25A' : '#0092CF'} stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 12l2 2 4-4" />
              <circle cx="12" cy="12" r="10" />
            </svg>
          </div>
          <h2 class="font-serif text-[1.6rem] text-dark">{section.category}</h2>
        </div>

        <div class="grid gap-4">
          {section.items.map((item) => (
            <div class="bg-white rounded-xl p-6 border border-border">
              <h3 class="font-semibold text-dark mb-2">{item.credit}</h3>
              <p class="text-[0.9rem] text-text-muted leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Certified Projects -->
  <section class="py-12 md:py-20 bg-dark">
    <div class="container">
      <div class="section-header">
        <span class="tag">Proven Results</span>
        <h2 class="!text-white">LEED Certified Projects Using LiveRoof</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-[900px] mx-auto">
        {certifiedProjects.map((project) => (
          <div class="bg-white/[0.06] border border-white/10 rounded-xl px-5 py-4 flex items-center justify-between">
            <span class="text-white text-[0.9rem] font-medium">{project.name}</span>
            <span class={`chip ${project.level === 'Platinum' ? 'green' : project.level === 'Gold' ? 'blue' : 'dark'} text-[0.6rem]`}>{project.level}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
