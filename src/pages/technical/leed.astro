---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const credits = [
  {
    category: 'Sustainable Sites',
    color: 'green',
    items: [
      { credit: 'Site Development – Protect or Restore Habitat & Maximize Open Space', desc: 'Green roofs reclaim vegetated space where buildings exist, providing habitat for songbirds, butterflies, and invertebrate species while promoting biodiversity on otherwise impermeable surfaces. Green roofs count toward open space requirements under LEEDv4.' },
      { credit: 'Rainwater Management', desc: 'LiveRoof systems reduce excess stormwater discharge through evapotranspiration and infiltration. They filter and detoxify stormwater by removing suspended solids and pollutants before it reaches waterways.' },
      { credit: 'Heat Island Reduction', desc: 'LiveRoof significantly reduces summer roof temperatures. The LEED Reference Guide identifies green roofs as effective urban heat island mitigation. In LEEDv4, vegetated and high-reflectance roofs carry equal weight in compliance calculations.' },
    ],
  },
  {
    category: 'Water Efficiency',
    color: 'blue',
    items: [
      { credit: 'Outdoor Water Use Reduction', desc: 'Drought-resistant LiveRoof plants require minimal irrigation — significantly less than 50% of typical irrigation needs. Some climates support growth with little or no supplemental irrigation. The growing medium functions like a sponge, collecting and feeding vegetation, evaporating, and filtering excess rainwater. Collected runoff can be redirected to cisterns or rain gardens for landscape reuse, reducing overall potable water requirements.' },
    ],
  },
  {
    category: 'Energy & Atmosphere',
    color: 'green',
    items: [
      { credit: 'Optimize Energy Performance', desc: 'In northern temperate zones, air conditioning energy savings are expected to exceed 25% on single-story structures. Warmer climates experience longer energy savings periods. Exact savings depend on building type, site exposure, atmospheric conditions, and soil moisture content. For LEEDv4, multiple efficiency measures help meet stricter ASHRAE 90.1-2010 requirements. The LiveRoof Standard System (4.25" soil depth) maintains an R-value of approximately 1.9 during winter.' },
    ],
  },
  {
    category: 'Materials & Resources',
    color: 'blue',
    items: [
      { credit: 'Construction and Demolition Waste Management', desc: 'LiveRoof modules arrive on reusable Hoppit racks, eliminating typical pallet and cardboard disposal requirements. Removed soil elevators can be recycled and returned via truck delivery.' },
      { credit: 'Building Product Disclosure and Optimization – Environmental Product Declarations', desc: 'Green roofs extend membrane life by 200–300%, significantly reducing life-cycle environmental impact and supporting product transparency documentation under LEEDv4.' },
      { credit: 'Building Product Disclosure and Optimization – Sourcing of Raw Materials', desc: 'LiveRoof modules are composed of 100% recycled polypropylene (average 10% post-consumer, 90% post-industrial). Growing medium often contains recycled materials such as compost or reclaimed mineral aggregate, diverting resources from landfills. Modules are manufactured across the United States and Canada. Growers can provide detailed assembly calculations per LEED guidelines.' },
      { credit: 'Building Product Disclosure and Optimization – Material Ingredients', desc: 'Most LiveRoof plants are repeatedly harvested without soil disturbance or replanting — similar to bamboo. This reduces carbon and fertilizer inputs while preventing farmland erosion. Constitutes rapidly renewable materials under LEED criteria.' },
    ],
  },
  {
    category: 'Innovation in Design',
    color: 'green',
    items: [
      { credit: 'Innovation Credits', desc: 'Green roofs support innovation through multiple pathways: enhanced workplace productivity, outdoor meeting and relaxation spaces, educational opportunities, integrated patios and outdoor kitchens, herb and vegetable cultivation, honeybee farming, sound reduction, carbon sequestration, wildlife-friendly design, plant preservation, non-chemical water treatment, acid rain buffering, and sustainable maintenance methods including Integrated Pest Management (IPM) and organic growing practices.' },
    ],
  },
  {
    category: 'Regional Priority Credits',
    color: 'blue',
    items: [
      { credit: 'Regional Priority', desc: 'Additional points may be available depending on geographic location for vegetated roofs or green roofs designed with multiple environmental functions. These credits recognize locally significant environmental priorities and reward projects that address them.' },
    ],
  },
];

const certifiedProjects = [
  { name: 'Zurich North America HQ', level: 'Platinum' },
  { name: 'Van Andel Institute Expansion', level: 'Platinum' },
  { name: 'WMS Gaming HQ', level: 'Platinum' },
  { name: 'Aurora Sinai Hospital', level: 'Gold' },
  { name: 'Mariano Azuela Elementary', level: 'Gold' },
  { name: 'GVSU Boat House', level: 'Gold' },
  { name: 'Monroe Clinic Hospital', level: 'Silver' },
];
---

<Layout title="LEED Resources – LiveRoof Technical Resources">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="LEED"
    title="LEED"
    highlight="Resources"
    subtitle="How LiveRoof green roof systems contribute to LEED certification across multiple credit categories."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Technical', href: '/technical' },
      { label: 'LEED' },
    ]}
  />

  <!-- Definition -->
  <section class="py-12 bg-mid">
    <div class="container">
      <div class="max-w-[760px] mx-auto text-center">
        <p class="text-text-muted leading-relaxed mb-4">
          <strong class="text-dark">LEED</strong> (Leadership in Energy and Environmental Design) is a green building
          rating system developed by the U.S. Green Building Council (USGBC). It establishes standard certification
          procedures emphasizing five core areas of environmental and human health. Projects must meet prerequisites
          and accumulate points through various credits to achieve certification.
        </p>
        <p class="text-text-muted leading-relaxed">
          LiveRoof systems have supported dozens of LEED-certified projects and can help earn points across
          multiple credit categories.
        </p>
      </div>
    </div>
  </section>

  <!-- Credit Categories -->
  {credits.map((section, sIdx) => (
    <section class={`py-16 ${sIdx % 2 === 0 ? 'bg-white' : 'bg-mid'}`}>
      <div class="container">
        <div class="flex items-center gap-4 mb-8">
          <div class={`w-10 h-10 rounded-lg flex items-center justify-center ${section.color === 'green' ? 'bg-green-light' : 'bg-blue-light'}`}>
            <svg width="20" height="20" fill="none" stroke={section.color === 'green' ? '#00B25A' : '#0092CF'} stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 12l2 2 4-4" />
              <circle cx="12" cy="12" r="10" />
            </svg>
          </div>
          <h2 class="font-serif text-[1.6rem] text-dark">{section.category}</h2>
        </div>

        <div class="grid gap-4">
          {section.items.map((item) => (
            <div class="bg-white rounded-xl p-6 border border-border">
              <h3 class="font-semibold text-dark mb-2">{item.credit}</h3>
              <p class="text-[0.9rem] text-text-muted leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Certified Projects -->
  <section class="py-12 md:py-20 bg-dark">
    <div class="container">
      <div class="section-header">
        <span class="tag">Proven Results</span>
        <h2 class="!text-white">LEED Certified Projects Using LiveRoof</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-[900px] mx-auto">
        {certifiedProjects.map((project) => (
          <div class="bg-white/[0.06] border border-white/10 rounded-xl px-5 py-4 flex items-center justify-between">
            <span class="text-white text-[0.9rem] font-medium">{project.name}</span>
            <span class={`chip ${project.level === 'Platinum' ? 'green' : project.level === 'Gold' ? 'blue' : 'dark'} text-[0.6rem]`}>{project.level}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
