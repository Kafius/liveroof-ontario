---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const courses = [
  {
    title: 'Green Roof Best Practices and Common Mistakes to Avoid',
    objectives: [
      'Types of Green Roofs: Learn to identify 4 types — Extensive, Semi-intensive, Intensive, and Blue-Green.',
      'Benefits of Green Roofs: Identify multiple benefits including longer roofing life spans, stormwater management, beautification, energy savings, habitat creation, and expanding usable space.',
      'Green Roof Accessories and Plants: Understand accessories and plants to assist with writing conscientious specifications.',
      'Things to Avoid: Learn the most common green roof mistakes — the importance of specifying transitional maintenance, irrigation, and what to do with dead air spaces.',
    ],
  },
  {
    title: 'Bio-Solar Roofs — Combining Green Roofs + Photovoltaic Energy Generation',
    objectives: [
      'Learn about the many benefits (biophilic, environmental, community, social and economic) and market drivers of green roofs.',
      'Learn about the benefits, rationale, feasibility, and electrical basics of solar (PV) energy generation.',
      'Develop an understanding of the costs of traditional grid electricity compared to Solar (PV) power generation and how green roofs can lower the cost of PV power.',
      'Learn about the design and logistical considerations of Bio-Solar Roofs.',
    ],
  },
];
---

<Layout title="Continuing Education – LiveRoof Technical Resources">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Continuing Education"
    title="Continuing"
    highlight="Education"
    subtitle="AIA-approved courses on green roof best practices and bio-solar roof design."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Technical', href: '/technical' },
      { label: 'Continuing Education' },
    ]}
  />

  <!-- Intro -->
  <section class="py-12 bg-mid">
    <div class="container">
      <div class="bg-white rounded-xl p-6">
        <p class="text-text-muted leading-relaxed">
          Below are our current AIA-approved courses. If you would like to have a Lunch and Learn
          in your region, contact us to connect with a sales representative in your area, or call
          our main office at <a href="tel:18008751392" class="text-blue font-semibold hover:underline">(800) 875-1392</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Courses -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid gap-12">
        {courses.map((course, i) => (
          <div class="bg-mid rounded-xl p-8 lg:p-10">
            <span class="chip green mb-4">AIA Approved</span>
            <h2 class="font-serif text-[1.6rem] text-dark mb-6">{course.title}</h2>

            <h3 class="text-[0.75rem] font-bold text-text-muted uppercase tracking-wider mb-4">Learning Objectives</h3>
            <div class="grid gap-4">
              {course.objectives.map((obj, j) => (
                <div class="flex gap-4 items-start bg-white rounded-xl p-5">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green text-white flex items-center justify-center font-serif text-[0.9rem]">{j + 1}</span>
                  <p class="text-[0.9rem] text-text-muted leading-relaxed pt-1">{obj}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
