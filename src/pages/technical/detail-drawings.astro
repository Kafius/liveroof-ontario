---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const categories = [
  {
    title: 'LiveRoof Modules Over Conventional Roof',
    drawings: [
      'Lite Conventional (2.5" soil depth)',
      'Standard Conventional (4.25" soil depth)',
      'Deep Conventional (6" soil depth)',
      'Maxx Conventional (8" soil depth)',
    ],
  },
  {
    title: 'LiveRoof Modules Over Protective Membrane Assembly',
    drawings: [
      'Lite PMA (2.5" soil depth)',
      'Standard PMA (4.25" soil depth)',
      'Deep PMA (6" soil depth)',
      'Maxx PMA (8" soil depth)',
    ],
  },
  {
    title: 'RoofEdge Aluminum Edging',
    drawings: [
      'Lite Restraint (2.5")',
      'Standard Restraint (4.25")',
      'Deep Restraint (6.5")',
      'Maxx Restraint (8.5")',
      'Roof Anchor Detail',
    ],
  },
  {
    title: 'Pavers & Drain Boxes',
    drawings: [
      'RoofStone with Standard Modules',
      'RoofStone with Deep Modules',
      'RoofStone Maxx',
      'Conventional Pedestal Paver',
      'Drain Box with RoofEdge',
      'Drain Dome with RoofEdge & Stone Ballast',
      'Module Interface with Pedestal/Paver (Foam System)',
      'Module Interface with Pedestal/Paver (Grating System)',
    ],
  },
  {
    title: 'RoofBlue RETAIN & DETAIN',
    drawings: [
      'RoofBlue RETAIN with Lite Modules',
      'RoofBlue RETAIN with Standard Modules',
      'RoofBlue RETAIN with Deep Modules',
      'RoofBlue RETAIN with Maxx Modules',
      'RoofBlue DETAIN with Lite Modules',
      'RoofBlue DETAIN with Standard Modules',
      'RoofBlue DETAIN with Deep Modules',
      'RoofBlue DETAIN with Maxx Modules',
    ],
  },
  {
    title: 'Other Details',
    drawings: [
      'PipeRunner with Standard Module',
      'Gutter A — Low Slope Application',
      'Perimeter A — Custom-Cut Modules',
      'SolaGreen Panel Racking System',
    ],
  },
];
---

<Layout title="Detail Drawings – LiveRoof Technical Resources">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Detail Drawings"
    title="Detail"
    highlight="Drawings"
    subtitle="Technical details in PDF and DWG (AutoCAD) formats for use in plans and to accompany specifications."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Technical', href: '/technical' },
      { label: 'Detail Drawings' },
    ]}
  />

  <!-- Download All -->
  <section class="py-12 bg-mid">
    <div class="container">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 bg-white rounded-xl p-6">
        <div>
          <h3 class="font-semibold text-dark mb-1">Download All LiveRoof Details</h3>
          <p class="text-[0.85rem] text-text-muted">Or use our <a href="/technical/spec-writer" class="text-blue hover:underline">Spec Writer</a> to download only the relevant details in one zipped file.</p>
        </div>
        <div class="flex gap-3">
          <a href="#" class="btn btn-primary">PDF</a>
          <a href="#" class="btn btn-outline-dark">DWG</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Drawing Categories -->
  {categories.map((cat, cIdx) => (
    <section class={`py-16 ${cIdx % 2 === 0 ? 'bg-white' : 'bg-mid'}`}>
      <div class="container">
        <h2 class="font-serif text-[1.6rem] text-dark mb-8">{cat.title}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {cat.drawings.map((drawing) => (
            <div class="flex items-center justify-between bg-white rounded-xl px-5 py-4 border border-border">
              <span class="text-[0.9rem] text-dark font-medium pr-4">{drawing}</span>
              <div class="flex gap-2 flex-shrink-0">
                <a href="#" class="text-[0.72rem] font-bold uppercase tracking-wider text-blue hover:text-green transition-colors">PDF</a>
                <span class="text-border">|</span>
                <a href="#" class="text-[0.72rem] font-bold uppercase tracking-wider text-blue hover:text-green transition-colors">DWG</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <CtaBanner />
  <Footer />
</Layout>
