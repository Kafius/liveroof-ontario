---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const sections = [
  {
    title: 'Design & Engineering',
    description: 'Fire safety, irrigation design, job site safety, plant design, roof membranes, stormwater management, slope considerations, and wind resistance.',
    href: 'https://liveroof.com/technical/design/',
    chip: 'Design',
  },
  {
    title: 'Design Guide',
    description: 'Comprehensive design guide covering LiveRoof system planning, loading, drainage, and integration with building systems.',
    href: 'https://liveroof.com/technical/design-guide/',
    chip: 'Guide',
  },
  {
    title: 'Detail Drawings',
    description: 'Technical details in PDF and DWG formats for all module types, RoofEdge, RoofStone, RoofBlue, PipeRunner, and SolaGreen.',
    href: 'https://liveroof.com/technical/detail-drawings/',
    chip: 'Drawings',
  },
  {
    title: 'Installation',
    description: 'Installation guides and videos for LiveRoof modules, RoofEdge, RoofStone, RoofBlue, WindDisc, and SolaGreen.',
    href: 'https://liveroof.com/technical/installation/',
    chip: 'Install',
  },
  {
    title: 'LEED Resources',
    description: 'How LiveRoof contributes to LEED certification across Sustainable Sites, Water Efficiency, Energy, Materials, and Innovation credits.',
    href: 'https://liveroof.com/technical/leed/',
    chip: 'LEED',
  },
  {
    title: 'Maintenance & Operations',
    description: 'Maintenance philosophy, operation manuals, and seasonal reminders to protect your vegetative roof investment.',
    href: 'https://liveroof.com/technical/maintenance/',
    chip: 'Maintenance',
  },
  {
    title: 'Spec Writer',
    description: 'Generate customized vegetative roof specifications for your project with our interactive tool.',
    href: 'https://liveroof.com/technical/spec-writer/',
    chip: 'Specs',
  },
  {
    title: 'Continuing Education',
    description: 'AIA-approved courses on vegetative roof best practices and bio-solar roof design.',
    href: 'https://liveroof.com/technical/continuing-education/',
    chip: 'AIA/CEU',
  },
  {
    title: 'Videos',
    description: 'Installation guides, project spotlights, and product overviews from the LiveRoof team.',
    href: 'https://liveroof.com/videos/',
    chip: 'Videos',
  },
];
---

<Layout title="Technical Resources – LiveRoof Vegetative Roof Systems">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Technical"
    title="Technical"
    highlight="Resources"
    subtitle="Design guides, detail drawings, installation instructions, LEED resources, and everything you need to specify and maintain a LiveRoof system."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Technical' },
    ]}
  />

  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sections.map((s) => (
          <a href={s.href} class="group block bg-mid rounded-xl p-8 transition-all hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(35,31,32,0.1)] hover:border-blue border border-transparent">
            <span class="chip green mb-3">{s.chip}</span>
            <h3 class="font-serif text-[1.4rem] text-dark mb-2 group-hover:text-blue transition-colors">{s.title}</h3>
            <p class="text-[0.9rem] text-text-muted leading-relaxed">{s.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
