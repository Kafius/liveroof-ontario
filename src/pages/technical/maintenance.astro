---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Maintenance & Operations – LiveRoof Technical Resources">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Maintenance"
    title="Maintenance &"
    highlight="Operations"
    subtitle="The key to simple and easy green roof maintenance lies in frequent, short visits."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Technical', href: '/technical' },
      { label: 'Maintenance & Operations' },
    ]}
  />

  <!-- Philosophy -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 lg:gap-16 items-center">
        <div>
          <span class="tag">Maintenance Philosophy</span>
          <h2 class="font-serif text-[2rem] text-dark mb-5">Frequent, Brief Visits Are Key</h2>
          <p class="text-text-muted leading-relaxed mb-4">
            Some suppliers suggest 1 or 2 months between maintenance visits is reasonable — but we
            disagree. Weeds reproduce rapidly. One weed may turn into dozens between visits. And if
            those dozens had the opportunity to reproduce, they become hundreds, which in turn can
            become thousands.
          </p>
          <p class="text-text-muted leading-relaxed">
            By weeding every 2 weeks for just a few minutes, the few weeds that come from birds and
            the wind are never allowed to reproduce. Lean, preventative maintenance is far more
            effective and economical than reactive maintenance.
          </p>
        </div>
        <div class="photo-placeholder rounded-xl aspect-[4/3]">
          <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <rect x="3" y="3" width="18" height="18" rx="3" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
          </svg>
          <span>Green Roof Maintenance</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Operation Manual -->
  <section class="py-12 md:py-20 bg-mid">
    <div class="container">
      <div class="max-w-[640px] mx-auto text-center">
        <span class="tag">Resources</span>
        <h2 class="font-serif text-[2rem] text-dark mb-5">Operation Manual</h2>
        <p class="text-text-muted leading-relaxed mb-4">
          Different climates and vegetation types call for different care protocols. We have developed
          a tool that allows us to quickly generate customized operation manuals for each project.
        </p>
        <p class="text-text-muted leading-relaxed mb-8">
          To receive your copy, contact your LiveRoof representative.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#" class="btn btn-primary">Download Operation Manual (PDF)</a>
          <a href="/contact" class="btn btn-outline-dark">Contact Your Rep</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Video -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="relative aspect-video bg-dark rounded-xl flex items-center justify-center">
          <div class="flex flex-col items-center gap-3 text-white/40">
            <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
            <span class="text-[0.72rem] uppercase tracking-wider font-semibold">Maintenance Video</span>
          </div>
        </div>
        <div>
          <span class="tag">Video Tutorial</span>
          <h2 class="font-serif text-[1.8rem] text-dark mb-4">Proper Maintenance Techniques</h2>
          <p class="text-text-muted leading-relaxed">
            Watch our step-by-step maintenance guide covering proper weeding techniques, irrigation
            monitoring, soil fertility management, and seasonal care protocols for your LiveRoof
            green roof system.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="py-10 md:py-16 bg-dark">
    <div class="container">
      <div class="max-w-[540px] mx-auto text-center">
        <h2 class="font-serif text-[1.8rem] text-white mb-4">Monthly Maintenance Updates</h2>
        <p class="text-white/60 leading-relaxed mb-8">
          Sign up for seasonal reminders and maintenance tips delivered once a month from March through November.
        </p>
        <form class="flex flex-col sm:flex-row gap-3" action="#" method="POST">
          <input
            type="email"
            name="email"
            placeholder="Your email address"
            required
            class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white text-[0.92rem] placeholder-white/40 outline-none focus:border-green focus:ring-1 focus:ring-green"
          />
          <button type="submit" class="btn btn-primary flex-shrink-0">Sign Up</button>
        </form>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
