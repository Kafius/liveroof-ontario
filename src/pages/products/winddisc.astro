---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import ProductPageLayout from '../../components/ProductPageLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const projects = [
  { name: 'Wolf Point', desc: 'Green roof visible on multiple floor levels of the building.' },
  { name: '1001 South State', desc: 'Helps manage stormwater runoff in an urban environment.' },
  { name: '850 N. Lakeshore', desc: 'Sculpted mounds give residents a place to relax in downtown Chicago.' },
  { name: 'Fox Ford', desc: '34,000 sq ft living roof reduces cooling costs and manages stormwater. Lite system for lower weight capacity.' },
];
---

<Layout title="WindDisc Wind Uplift Solution – LiveRoof Products">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Accessory"
    title="WindDisc®"
    highlight="Wind Uplift Solution"
    subtitle="A simple way to secure LiveRoof modules together for a sustained 200 PSF wind uplift rating."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products' },
      { label: 'WindDisc' },
    ]}
  />

  <ProductPageLayout name="WindDisc" tagline="Typically specified for high-rise buildings or regions prone to hurricanes.">
    <span class="tag">How It Works</span>
    <h2 class="font-serif text-[2rem] text-dark mb-4">Simple, Proven Wind Protection</h2>
    <p class="text-text-muted leading-relaxed mb-6">
      WindDisc is a simple way to secure LiveRoof modules together to improve wind uplift resistance.
      A full-scale wind resistance test resulted in a <strong class="text-green font-semibold">sustained 200 PSF (9.6 kPa) rating</strong> for
      the Standard and Lite systems. Similar performance is expected for the heavier Deep and Maxx systems.
    </p>

    <!-- Installation Steps -->
    <div class="space-y-4 mb-12">
      <div class="flex gap-4 items-start bg-mid rounded-xl p-5">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green text-white flex items-center justify-center font-serif">1</span>
        <p class="text-[0.92rem] text-text-muted leading-relaxed pt-1">Tap discs into slots between rows of adjacent modules.</p>
      </div>
      <div class="flex gap-4 items-start bg-mid rounded-xl p-5">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green text-white flex items-center justify-center font-serif">2</span>
        <p class="text-[0.92rem] text-text-muted leading-relaxed pt-1">Slide the next row of modules into place over the discs.</p>
      </div>
    </div>

    <!-- When to Use -->
    <span class="tag">Applications</span>
    <h3 class="font-serif text-[1.5rem] text-dark mb-4">When to Specify WindDisc</h3>
    <p class="text-text-muted leading-relaxed mb-8">
      WindDisc is typically specified for use on high-rise buildings or in regions prone to hurricanes
      or other high wind storms. Contact your LiveRoof representative for detail drawings and System Properties sheets.
    </p>

    <!-- Featured Projects -->
    <span class="tag">Featured Projects</span>
    <h3 class="font-serif text-[1.5rem] text-dark mb-4">WindDisc in Action</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {projects.map((project) => (
        <div class="bg-mid rounded-xl overflow-hidden">
          <div class="photo-placeholder aspect-[16/10]">
            <span class="text-[0.65rem]">{project.name}</span>
          </div>
          <div class="p-5">
            <h4 class="font-semibold text-dark mb-1">{project.name}</h4>
            <p class="text-[0.85rem] text-text-muted leading-relaxed">{project.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </ProductPageLayout>

  <CtaBanner />
  <Footer />
</Layout>
