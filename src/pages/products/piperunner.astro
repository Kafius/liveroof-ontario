---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import ProductPageLayout from '../../components/ProductPageLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="PipeRunner Irrigation Channels – LiveRoof Products">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Accessory"
    title="PipeRunner™"
    highlight="Irrigation Channels"
    subtitle="A simple part that cradles irrigation pipes between module rows — keeping your green roof irrigation system clean and organized."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products' },
      { label: 'PipeRunner' },
    ]}
  />

  <ProductPageLayout name="PipeRunner" tagline="Engineered for overhead and lateral drip irrigation systems.">
    <span class="tag">Overview</span>
    <h2 class="font-serif text-[2rem] text-dark mb-4">Simple & Effective Irrigation Management</h2>
    <p class="text-text-muted leading-relaxed mb-6">
      PipeRunner is a simple part that rests between two rows of modules and cradles an irrigation pipe.
      PipeRunner pieces have gaps to allow water flow, and extend along the sides to prevent soil from
      spilling between modules.
    </p>

    <!-- How It Works -->
    <span class="tag">Installation</span>
    <h3 class="font-serif text-[1.5rem] text-dark mb-4">How to Use PipeRunner</h3>
    <div class="space-y-4 mb-12">
      <div class="flex gap-4 items-start bg-mid rounded-xl p-5">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green text-white flex items-center justify-center font-serif">1</span>
        <p class="text-[0.92rem] text-text-muted leading-relaxed pt-1">Place PipeRunner lengths between rows of LiveRoof modules.</p>
      </div>
      <div class="flex gap-4 items-start bg-mid rounded-xl p-5">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green text-white flex items-center justify-center font-serif">2</span>
        <p class="text-[0.92rem] text-text-muted leading-relaxed pt-1">Lay irrigation lines over the PipeRunner channels.</p>
      </div>
      <div class="flex gap-4 items-start bg-mid rounded-xl p-5">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green text-white flex items-center justify-center font-serif">3</span>
        <p class="text-[0.92rem] text-text-muted leading-relaxed pt-1">Cover the system with engineered green roof soil.</p>
      </div>
    </div>

    <!-- Key Features -->
    <span class="tag">Features</span>
    <h3 class="font-serif text-[1.5rem] text-dark mb-4">Designed for Performance</h3>
    <ul class="space-y-3">
      {[
        'Cradles irrigation pipes securely between module rows',
        'Gaps allow unimpeded water flow across the roof',
        'Side extensions prevent soil spillage between modules',
        'Compatible with overhead and lateral drip irrigation',
        'Simple, tool-free installation',
        'Integrates seamlessly with all LiveRoof module sizes',
      ].map((feature) => (
        <li class="flex items-start gap-3">
          <svg class="flex-shrink-0 mt-1 text-green" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-[0.9rem] text-text-muted">{feature}</span>
        </li>
      ))}
    </ul>
  </ProductPageLayout>

  <CtaBanner />
  <Footer />
</Layout>
