---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import ProductPageLayout from '../../components/ProductPageLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const modules = [
  {
    name: 'Standard Module',
    soil: '~4.25"',
    satWeight: '~29 lbs/sq ft',
    dryWeight: '~20 lbs/sq ft',
    size: '1\' x 2\' x 3.25"',
    description: 'The workhorse — used on 80%+ of LiveRoof projects. Provides exceptional stormwater management, significant energy savings, and supports pollinators.',
    plants: 'Full array of low to tall growing sedums, Alliums, and with regular irrigation some low-growing grasses like little bluestem or prairie dropseed.',
    growth: '8–12 weeks',
    highlight: true,
  },
  {
    name: 'Deep Module',
    soil: '~6"',
    satWeight: '~40–50 lbs/sq ft',
    dryWeight: '~30 lbs/sq ft',
    size: '1\' x 2\' x 3.25"',
    description: 'For biodiverse green roofs. Supports a broad array of non-succulent plants — create a prairie or shade garden on the roof. Requires built-in irrigation.',
    plants: 'Hundreds of fibrous rooted herbaceous perennials including native forbs, sedges, grasses, and edible plants.',
    growth: '10–16 weeks',
  },
  {
    name: 'Lite Module',
    soil: '~2.5"',
    satWeight: '~15–17 lbs/sq ft',
    dryWeight: '~12 lbs/sq ft',
    size: '1\' x 2\' x 1.75"',
    description: 'Designed for retrofit projects on roofs engineered for 15–17 lbs/sq ft. Provides modest stormwater management and energy savings.',
    plants: 'Fairly broad range of low growing Sedums — mostly fine- and medium-textured, as well as a few Alliums.',
    growth: '8–12 weeks',
  },
  {
    name: 'Maxx Module',
    soil: '~8"',
    satWeight: '~60–65 lbs/sq ft',
    dryWeight: '~40 lbs/sq ft',
    size: '1\' x 1\' x 3.25"',
    description: 'A niche product for unique needs — vegetable gardening on decks and balconies, biodiverse prairies, sun or shade gardens.',
    plants: 'Most popular edibles including herbs, peppers, tomatoes, kale, beans, carrots, cabbage, even sweet corn.',
    growth: '8–16 weeks',
  },
];

const steps = [
  'LiveRoof Licensed Grower inserts Soil Elevators™ into the LiveRoof module.',
  'Module is filled to the top of Soil Elevators with engineered soil.',
  'Plants are grown to maturity in soil that extends above the module.',
  'Upon delivery, installer sets modules tightly in place from parapet to parapet.',
  'Soil Elevators are removed for a seamless, instantly mature green roof.',
  'The entire system is watered thoroughly to settle soil and get the system off to a great start.',
];
---

<Layout title="Green Roof Modules – LiveRoof Products">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Core System"
    title="Green Roof"
    highlight="Modules"
    subtitle="The patented LiveRoof system creates a seamless, beautiful and instantly mature green roof. Four module options for the perfect match."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products' },
      { label: 'Modules' },
    ]}
  />

  <!-- Module Options -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="section-header">
        <span class="tag">Four Options</span>
        <h2>The Perfect Match for Every Project</h2>
        <p>The modules disappear under the cover of soil and plants — no ugly container edges or grid lines.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {modules.map((mod) => (
          <div class={`rounded-xl p-8 border-2 transition-all ${mod.highlight ? 'border-green bg-green-light/30 shadow-[0_4px_24px_rgba(0,178,90,0.1)]' : 'border-border bg-white'}`}>
            {mod.highlight && <span class="chip green mb-4">Most Popular</span>}
            <h3 class="font-serif text-[1.5rem] text-dark mb-2">{mod.name}</h3>
            <p class="text-[0.92rem] text-text-muted leading-relaxed mb-6">{mod.description}</p>

            <div class="grid grid-cols-2 gap-4 mb-6">
              <div class="bg-mid rounded-lg p-4">
                <div class="text-[0.7rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Soil Depth</div>
                <div class="text-dark font-semibold">{mod.soil}</div>
              </div>
              <div class="bg-mid rounded-lg p-4">
                <div class="text-[0.7rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Module Size</div>
                <div class="text-dark font-semibold text-[0.9rem]">{mod.size}</div>
              </div>
              <div class="bg-mid rounded-lg p-4">
                <div class="text-[0.7rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Saturated Wt.</div>
                <div class="text-dark font-semibold text-[0.9rem]">{mod.satWeight}</div>
              </div>
              <div class="bg-mid rounded-lg p-4">
                <div class="text-[0.7rem] text-text-muted uppercase tracking-wider font-semibold mb-1">Growth Time</div>
                <div class="text-dark font-semibold">{mod.growth}</div>
              </div>
            </div>

            <div class="border-t border-border pt-4">
              <div class="text-[0.7rem] text-text-muted uppercase tracking-wider font-semibold mb-2">Compatible Plants</div>
              <p class="text-[0.85rem] text-text-muted leading-relaxed">{mod.plants}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-14 md:py-24 bg-mid">
    <div class="container">
      <div class="section-header">
        <span class="tag">Installation</span>
        <h2>How LiveRoof Works</h2>
        <p>Six simple steps from grower to gorgeous green roof.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {steps.map((step, i) => (
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-green flex items-center justify-center text-white font-serif text-[1.2rem]">
              {i + 1}
            </div>
            <p class="text-[0.92rem] text-text-muted leading-relaxed pt-2">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
