---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const singleSourceProviders = [
  { name: 'Barrett Company', region: 'US Only' },
  { name: 'CertainTeed', region: 'US Only' },
  { name: 'Flex Membranes', region: 'US & Canada' },
  { name: 'GAF', region: 'US & Canada' },
  { name: 'Kemper System', region: 'US Only' },
  { name: 'Sika Hydrotech', region: 'US & Canada' },
];
---

<Layout title="Warranty – LiveRoof Products">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Warranty"
    title="Warranty"
    highlight="Options"
    subtitle="Every LiveRoof product is backed by industry-leading warranties designed to protect your investment for decades."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products' },
      { label: 'Warranty' },
    ]}
  />

  <!-- Module Warranty -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 lg:gap-16 items-center">
        <div>
          <span class="tag">Module Warranty</span>
          <h2 class="font-serif text-[2.2rem] leading-[1.18] text-dark mb-5">
            50-Year Module Warranty
          </h2>
          <p class="text-text-muted leading-relaxed mb-4">
            The LiveRoof module is warranted against material defects and photodegradation for
            <strong class="text-green font-semibold">50 years</strong> from the date of installation,
            provided the system remains soil-covered and is surrounded by edging, RoofStone pavers,
            or parapet.
          </p>
          <p class="text-text-muted leading-relaxed">
            This warranty reflects our confidence in the durability and longevity of the LiveRoof
            system — engineered to protect your building for decades.
          </p>
        </div>

        <div class="bg-green-light/40 border border-green/20 rounded-xl p-10 text-center">
          <div class="font-serif text-[4rem] text-green leading-none mb-2">50</div>
          <div class="text-[0.82rem] text-dark uppercase tracking-wider font-bold mb-4">Year Warranty</div>
          <p class="text-[0.88rem] text-text-muted leading-relaxed">
            Against material defects and photodegradation from the date of installation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Plant Warranty -->
  <section class="py-14 md:py-24 bg-mid">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 lg:gap-16 items-start">
        <div class="photo-placeholder rounded-xl aspect-[4/3]">
          <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <rect x="3" y="3" width="18" height="18" rx="3" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
          </svg>
          <span>Green Roof Plants</span>
        </div>

        <div>
          <span class="tag">Plant Warranty</span>
          <h2 class="font-serif text-[2rem] text-dark mb-5">Plant Warranty</h2>
          <p class="text-text-muted leading-relaxed mb-4">
            Given that plants are living, breathing organisms, plant warranties are typically offered
            by the maintenance provider — not the LiveRoof grower or LiveRoof Global, LLC.
          </p>
          <p class="text-text-muted leading-relaxed mb-6">
            The maintenance contractor is in the best position to warrant the plants, as long-term
            plant health depends on proper care including keeping drains clean, preventing weed
            infiltration, watering during drought, and monitoring soil fertility.
          </p>

          <div class="bg-white rounded-xl p-6 border-l-4 border-green">
            <h4 class="font-semibold text-dark mb-2">Important Note</h4>
            <p class="text-[0.88rem] text-text-muted leading-relaxed">
              Plant warranties vary by licensed LiveRoof grower. Typically, plant warranties from
              growers are associated with additional charges and the adherence to and documentation
              of specific maintenance practices. Contact your local licensed grower for details.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Membrane Warranties -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="max-w-[760px] mx-auto text-center mb-16">
        <span class="tag">Membrane Compatibility</span>
        <h2 class="font-serif text-[2.2rem] text-dark mb-5">LiveRoof & Membrane Warranties</h2>
        <p class="text-text-muted leading-relaxed">
          LiveRoof is compatible with most methods of rooftop waterproofing — PVC, EPDM, TPO, Mod-bit,
          cold fluid, inverted, and conventional — and has been installed above products from nearly
          every roofing manufacturer in North America. Where the waterproofing manufacturer's
          specifications are followed, material and workmanship warranties have remained intact.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <div class="bg-mid rounded-xl p-8">
          <h3 class="font-serif text-[1.3rem] text-dark mb-3">Overburden Warranty</h3>
          <p class="text-[0.9rem] text-text-muted leading-relaxed">
            An optional for-fee warranty offered by some waterproofing manufacturers. This has nothing
            to do with material or workmanship warranties — it provides additional coverage for the
            green roof assembly above the membrane.
          </p>
        </div>
        <div class="bg-mid rounded-xl p-8">
          <h3 class="font-serif text-[1.3rem] text-dark mb-3">Single Source Warranty</h3>
          <p class="text-[0.9rem] text-text-muted leading-relaxed">
            Similar to an overburden warranty but promoted as a "make one call" warranty — simplifying
            the claims process by providing a single point of contact for both the membrane and the
            green roof system.
          </p>
        </div>
      </div>

      <!-- Single Source Providers -->
      <div>
        <h3 class="font-serif text-[1.5rem] text-dark mb-6 text-center">Single Source Warranty Providers</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {singleSourceProviders.map((provider) => (
            <div class="flex items-center justify-between bg-mid rounded-xl px-6 py-4">
              <span class="font-semibold text-dark text-[0.95rem]">{provider.name}</span>
              <span class="chip blue text-[0.65rem]">{provider.region}</span>
            </div>
          ))}
        </div>
        <div class="mt-6 bg-blue-light rounded-xl p-6 border border-blue/20">
          <p class="text-[0.88rem] text-text-muted leading-relaxed">
            <strong class="text-dark">Sika Hydrotech Note:</strong> LiveRoof systems may only be installed
            by Elite level LiveRoof Certified Installers and must be maintained by Elite LiveRoof
            Maintenance Contractors when covered under a Sika Hydrotech single source warranty.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LiveRoof Overburden Warranty -->
  <section class="py-12 md:py-20 bg-mid">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 lg:gap-16 items-center">
        <div>
          <span class="tag">Additional Coverage</span>
          <h2 class="font-serif text-[2rem] text-dark mb-5">LiveRoof Overburden Removal Warranty</h2>
          <p class="text-text-muted leading-relaxed mb-4">
            When overburden removal coverage is not available from a membrane manufacturer, LiveRoof's
            overburden removal warranty is available and may be purchased for terms of
            <strong class="text-green font-semibold">10, 15, or 20 years</strong>.
          </p>
          <p class="text-text-muted leading-relaxed mb-6">
            This warranty provides coverage for the costs to remove the green roof and to replace it
            after the leak has been serviced.
          </p>
          <div class="bg-white rounded-xl p-6 border-l-4 border-blue">
            <p class="text-[0.88rem] text-text-muted leading-relaxed">
              <strong class="text-dark">Installer Requirement:</strong> Only Diamond level Certified
              Installers are authorized to offer these warranties.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-4">
          {[10, 15, 20].map((years) => (
            <div class="bg-white rounded-xl p-6 text-center shadow-[0_2px_20px_rgba(35,31,32,0.06)]">
              <div class="font-serif text-[2.5rem] text-green leading-none mb-2">{years}</div>
              <div class="text-[0.72rem] text-text-muted uppercase tracking-wider font-semibold">Year Term</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
