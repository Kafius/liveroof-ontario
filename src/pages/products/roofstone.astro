---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import ProductPageLayout from '../../components/ProductPageLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const specs = [
  { label: 'Size', value: '24" L x 12" W x 4" H' },
  { label: 'Weight', value: '50 lbs' },
  { label: 'Compressive Strength', value: '5,000+ psi (exceeds SPRI by 50%+)' },
  { label: 'Flexural Strength', value: '770+ psi per ASTM C140' },
  { label: 'Water Absorption', value: '< 5% (cold water method)' },
  { label: 'Base Material', value: '95% post-industrial polypropylene' },
];

const advantages = [
  { title: 'Safer', text: 'Walk on for window washing and mechanical service. No sharp-edged stones to puncture membrane.' },
  { title: 'Money Saving', text: 'Installs 10x faster for 90% labor savings compared to traditional pedestal and paver solutions.' },
  { title: 'Easier', text: 'Materials delivered all-at-once with the green roof. Built-in handgrips and pedestals for fast installation.' },
  { title: 'More Attractive', text: 'Complements buildings and plants in four popular colors. Artisan surface with chamfered top edge.' },
];
---

<Layout title="RoofStone Integrated Pavers – LiveRoof Products">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Pavers"
    title="RoofStone®"
    highlight="Integrated Pavers"
    subtitle="Artisan-quality pavers with built-in pedestals. Installs in 1/10th the time of traditional pedestal and paver solutions."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products' },
      { label: 'RoofStone' },
    ]}
  />

  <ProductPageLayout name="RoofStone" tagline="Built-in pedestals for easy handling and installation. Available in four beautiful colors.">
    <span class="tag">Overview</span>
    <h2 class="font-serif text-[2rem] text-dark mb-4">A Better Alternative to Stone or Gravel Ballast</h2>
    <p class="text-text-muted leading-relaxed mb-4">
      In response to designer demand for an artisan-quality integrated green roof paver and
      contractor necessity for labor-saving solutions, LiveRoof developed the RoofStone paver system.
    </p>
    <p class="text-text-muted leading-relaxed mb-8">
      In a recent study, RoofStone pavers <strong class="text-green font-semibold">retained 25% of annual rainfall</strong>.
      ADA compliant when set on pitch of 1/4" per 1' or less.
    </p>

    <!-- Advantages -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
      {advantages.map((adv) => (
        <div class="bg-green-light/40 rounded-xl p-5 border border-green/20">
          <h4 class="font-semibold text-dark mb-1">{adv.title}</h4>
          <p class="text-[0.88rem] text-text-muted leading-relaxed">{adv.text}</p>
        </div>
      ))}
    </div>

    <!-- Specs -->
    <span class="tag">Specifications</span>
    <h3 class="font-serif text-[1.5rem] text-dark mb-4">Technical Details</h3>

    <div class="rounded-xl border border-border overflow-x-auto mb-12">
      <table class="w-full text-left">
        <tbody>
          {specs.map((spec, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-mid/50'}>
              <td class="px-5 py-3 font-semibold text-dark text-[0.9rem] w-[40%]">{spec.label}</td>
              <td class="px-5 py-3 text-text-muted text-[0.9rem]">{spec.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Key Features -->
    <span class="tag">Key Features</span>
    <h3 class="font-serif text-[1.5rem] text-dark mb-4">Designed for Performance</h3>
    <ul class="space-y-3 mb-8">
      {[
        'Integrates with LiveRoof Standard and Deep modules',
        'Integrates with WindDisc for enhanced wind uplift resistance',
        'Eliminates the need for RoofEdge between pavers and modules',
        'Follows roof contour',
        'Improved textured traction surface',
        'NanoTech MicroBubble™ technology resists impact and cracking',
        'Ample water channels for drainage',
        'Recycled plastic base',
      ].map((feature) => (
        <li class="flex items-start gap-3">
          <svg class="flex-shrink-0 mt-1 text-green" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-[0.9rem] text-text-muted">{feature}</span>
        </li>
      ))}
    </ul>
  </ProductPageLayout>

  <CtaBanner />
  <Footer />
</Layout>
