---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const retainFeatures = [
  'Holds 1.35 gallons per sq ft — in addition to water held by soil',
  'Increases stormwater retention 42% with Standard system',
  'Increases stormwater retention 55% with Lite system',
  'Outperformed mineral wool — 2 in. wool + 3 in. soil',
  'Improves irrigation efficiency, especially drip irrigation',
  'Lower cost per gallon of water-retained than other options',
  'Made from recycled material and is recyclable itself',
];

const detainBenefits = [
  'Reduce the burden on stormwater systems',
  'May allow for reduced drain size',
  'Reduce or eliminate need for cisterns, underground storage, and detention ponds',
  'Reduce stormwater utility charges',
  'May qualify for zoning incentives',
  'Reduce overall project cost vs other urban stormwater tools',
];

const detainSpecs = [
  { label: 'Water Detention', value: '~2 gallons (7.4 L) per sq ft' },
  { label: 'Dimensions', value: '24" L x 12" W x 3.75" H' },
  { label: 'Compressive Strength', value: 'Min 64 psi (9,200+ lbs/sq ft)' },
  { label: 'Installation', value: 'Set module into DETAIN and slide into place' },
];
---

<Layout title="RoofBlue Stormwater Solutions – LiveRoof Products">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Stormwater"
    title="RoofBlue®"
    highlight="Blue-Green Solutions"
    subtitle="Patented, effective, and sustainable stormwater management. Retain and detain rainwater right where it falls."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products' },
      { label: 'RoofBlue' },
    ]}
  />

  <!-- RoofBlue RETAIN -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <div>
          <div class="photo-placeholder rounded-xl aspect-[4/3]">
            <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="3" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
            </svg>
            <span>RoofBlue RETAIN</span>
          </div>
        </div>

        <div>
          <span class="chip blue mb-3">Retention</span>
          <h2 class="font-serif text-[2rem] text-dark mb-4">RoofBlue® RETAIN™</h2>
          <p class="text-text-muted leading-relaxed mb-4">
            A true "Cradle-to-Cradle" solution for enhanced stormwater capture. It captures and retains
            stormwater, then transfers it upward to plant roots for growth and transpiration after the storm event.
          </p>
          <p class="text-text-muted leading-relaxed mb-6">
            Follows years of development and testing, supported by university research, and
            <strong class="text-green font-semibold">outperformed typical mineral wool</strong> stormwater retention products.
          </p>

          <ul class="space-y-3 mb-8">
            {retainFeatures.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-1 text-blue" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-[0.9rem] text-text-muted">{feature}</span>
              </li>
            ))}
          </ul>

          <div class="bg-blue-light rounded-xl p-6 border border-blue/20">
            <h4 class="font-semibold text-dark mb-2">Sustainable by Design</h4>
            <p class="text-[0.88rem] text-text-muted leading-relaxed">
              Compared to mineral wool (large carbon footprint, disposal challenges), RoofBlue RETAIN
              is made from recycled material and is recyclable itself. It could be repurposed 100 years from now.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RoofBlue DETAIN -->
  <section class="py-14 md:py-24 bg-mid">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <div>
          <span class="chip green mb-3">Detention</span>
          <h2 class="font-serif text-[2rem] text-dark mb-4">RoofBlue® DETAIN</h2>
          <p class="text-text-muted leading-relaxed mb-6">
            Engineered to provide temporary water detention underneath all LiveRoof systems.
            When used with control flow drains, RoofBlue expands the usefulness of a green roof
            system as a stormwater management tool.
          </p>

          <ul class="space-y-3 mb-8">
            {detainBenefits.map((benefit) => (
              <li class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-1 text-green" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-[0.9rem] text-text-muted">{benefit}</span>
              </li>
            ))}
          </ul>

          <!-- Specs -->
          <div class="rounded-xl border border-border overflow-x-auto">
            <table class="w-full text-left">
              <tbody>
                {detainSpecs.map((spec, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-mid/50'}>
                    <td class="px-5 py-3 font-semibold text-dark text-[0.88rem] w-[40%]">{spec.label}</td>
                    <td class="px-5 py-3 text-text-muted text-[0.88rem]">{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <div class="photo-placeholder rounded-xl aspect-[4/3]">
            <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="3" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
            </svg>
            <span>RoofBlue DETAIN</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Retention vs Detention -->
  <section class="py-10 md:py-16 bg-dark">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="text-center p-8 border border-white/10 rounded-xl">
          <div class="chip blue mb-4">Retention</div>
          <h3 class="font-serif text-xl text-white mb-3">RETAIN</h3>
          <p class="text-white/60 text-[0.9rem] leading-relaxed">
            Water is retained on the roof indefinitely. After the storm, it transfers upward to plant roots
            for growth and transpiration — keeping soil moist and plants healthy.
          </p>
        </div>
        <div class="text-center p-8 border border-white/10 rounded-xl">
          <div class="chip green mb-4">Detention</div>
          <h3 class="font-serif text-xl text-white mb-3">DETAIN</h3>
          <p class="text-white/60 text-[0.9rem] leading-relaxed">
            Water is temporarily detained before controlled discharge. Delays flow to allow municipalities
            more time to treat runoff and prevent combined sewage overflows.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
