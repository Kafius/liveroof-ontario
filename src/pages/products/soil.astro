---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import ProductPageLayout from '../../components/ProductPageLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const engineeredFor = [
  'Be approximately 94%+ inorganic by dry weight — as found in ecologically stable, sustainable mature green roofs',
  'Conform to German FLL granulometric standards',
  'Filter rainwater and buffer acid rain',
  'Effectively grow LiveRoof plants',
  'Last for many decades',
];
---

<Layout title="Green Roof Soil – LiveRoof Products">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Growing Media"
    title="Green Roof"
    highlight="Engineered Soil"
    subtitle="A proprietary blend of the finest inorganic and organic materials formulated under strictly controlled standards."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products' },
      { label: 'Soil' },
    ]}
  />

  <ProductPageLayout name="LiveRoof Soil" tagline="Engineered Green Roof Soil™ — designed to be sustainable and the best on the market.">
    <span class="tag">Overview</span>
    <h2 class="font-serif text-[2rem] text-dark mb-4">Engineered to Exacting Standards</h2>
    <p class="text-text-muted leading-relaxed mb-6">
      LiveRoof Engineered Green Roof Soil™ is designed to be sustainable, used in conjunction with
      the LiveRoof module and to be the best green roof soil on the market. A proprietary blend of
      the finest inorganic and organic materials formulated under strictly controlled standards.
    </p>

    <!-- Engineered For -->
    <span class="tag">Specifications</span>
    <h3 class="font-serif text-[1.5rem] text-dark mb-4">Our Soil Is Engineered To:</h3>
    <ul class="space-y-3 mb-8">
      {engineeredFor.map((feature) => (
        <li class="flex items-start gap-3">
          <svg class="flex-shrink-0 mt-1 text-green" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-[0.9rem] text-text-muted">{feature}</span>
        </li>
      ))}
    </ul>

    <!-- Weight -->
    <div class="bg-mid rounded-xl p-6 mb-8">
      <h4 class="font-semibold text-dark mb-2">Weight Specification</h4>
      <p class="text-[0.9rem] text-text-muted leading-relaxed">
        LiveRoof Engineered Green Roof Soil weighs approximately <strong class="text-green font-semibold">27–29 lbs/sq ft</strong> fully
        saturated at 4.25" depth when fully vegetated with LiveRoof plants.
      </p>
    </div>

    <!-- Regional Note -->
    <div class="bg-blue-light rounded-xl p-6 border border-blue/20">
      <h4 class="font-semibold text-dark mb-2">Regional Variations</h4>
      <p class="text-[0.88rem] text-text-muted leading-relaxed">
        LiveRoof soil specifications will vary somewhat depending on region and available components.
        Consult your local grower for specifics tailored to your project's climate and conditions.
      </p>
    </div>
  </ProductPageLayout>

  <CtaBanner />
  <Footer />
</Layout>
