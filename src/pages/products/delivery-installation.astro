---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';

const equipment = [
  {
    name: 'Specialized Delivery Trucks',
    description: 'LiveRoof Licensed Growers may utilize retractable top trailers for fast and convenient delivery. Our commitment to effective material handling makes for simple, efficient unloading and conveyance to the rooftop — minimizing installation time and reducing cost.',
  },
  {
    name: 'Roll-a-Roof™ Rooftop Conveyors',
    description: 'Specialized Roll-a-Roof mobile conveyor systems available for job site use or rental. Motorized and set on wheels, they pay great dividends in labor savings on larger installations.',
  },
  {
    name: 'Hoppit® Truck-to-Roof Racks',
    description: 'Co-engineered conveyance racks that reduce installation time. A telescoping forklift or crane lifts the Hoppit directly over the roof surface, the team installs the modules, and the empty Hoppit returns to the truck.',
  },
];
---

<Layout title="Delivery & Installation Equipment – LiveRoof Products">
  <TopBar />
  <Header />

  <PageHero
    eyebrow="Equipment"
    title="Delivery &"
    highlight="Installation Equipment"
    subtitle="Transport and conveyance equipment that minimizes installation time and reduces the cost of green roof installation."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products' },
      { label: 'Delivery & Installation' },
    ]}
  />

  <!-- Equipment -->
  <section class="py-14 md:py-24 bg-white">
    <div class="container">
      <div class="grid gap-12">
        {equipment.map((item, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${i % 2 === 1 ? 'lg:[direction:rtl]' : ''}`}>
            <div class="photo-placeholder rounded-xl aspect-[16/10]">
              <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <rect x="3" y="3" width="18" height="18" rx="3" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
              </svg>
              <span>{item.name}</span>
            </div>
            <div class={i % 2 === 1 ? 'lg:[direction:ltr]' : ''}>
              <h2 class="font-serif text-[1.8rem] text-dark mb-4">{item.name}</h2>
              <p class="text-text-muted leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Hoppit Details -->
      <div class="mt-16 bg-mid rounded-xl p-8">
        <h3 class="font-serif text-[1.4rem] text-dark mb-4">Hoppit Capacity</h3>
        <p class="text-text-muted leading-relaxed mb-4">
          Depending on road load restrictions, a semi trailer fits up to 24 Hoppits with 36 Standard
          or Lite modules each — equating to <strong class="text-green font-semibold">864 modules or 1,728 sq ft of coverage per load</strong>.
          Approximately half the quantity of Maxx or Deep modules will fit per Hoppit.
        </p>
        <div class="bg-white rounded-lg p-5 border-l-4 border-green">
          <p class="text-[0.88rem] text-text-muted leading-relaxed">
            <strong class="text-dark">Safety Note:</strong> A loaded Hoppit can weigh as much as 2,200 pounds.
            Size your lifting equipment accordingly — lifting capacity and stability decrease with arm swing,
            extension, and boom height.
          </p>
        </div>
      </div>

      <!-- Installation CTA -->
      <div class="mt-12 text-center">
        <span class="tag">Resources</span>
        <h3 class="font-serif text-[1.8rem] text-dark mb-4">Installation Is Simple</h3>
        <p class="text-text-muted mb-8 max-w-[480px] mx-auto leading-relaxed">
          We make the process even easier with detailed written guides and videos that demonstrate
          how to install green roof products.
        </p>
        <a href="#" class="btn btn-primary">View Installation Resources</a>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
