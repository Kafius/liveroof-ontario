<section id="inspiration" class="scroll-mt-28 py-14 md:py-24 bg-mid">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
      <div class="rounded-xl overflow-hidden aspect-[4/3]">
        <img
          src="/images/coneflower-meadow-roof.jpeg"
          alt="A flourishing LiveRoof vegetated roof in full bloom"
          class="w-full h-full object-cover"
        />
      </div>

      <div>
        <span class="tag">Get Inspired</span>
        <h2 class="font-serif text-[2.2rem] leading-[1.18] text-dark mb-5">
          Explore the LiveRoof Inspiration Gallery
        </h2>
        <p class="text-base text-text-muted leading-[1.75] mb-4">
          Browse hundreds of completed vegetated roof projects from across North America — from
          lush urban meadows to expansive commercial installations — for design ideas and a look
          at what's possible with LiveRoof.
        </p>
        <p class="text-base text-text-muted leading-[1.75] mb-6">
          The full inspiration gallery is hosted on the LiveRoof Global website. Selecting the
          link below will let you know you're leaving liveroofontario.ca before you continue.
        </p>
        <a href="https://liveroof.com/inspiration/" class="btn btn-primary">
          View the Inspiration Gallery ↗
        </a>
      </div>
    </div>
  </div>
</section>
