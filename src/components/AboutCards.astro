---
const cards = [
  {
    img: '/images/meadow-roof-toronto.png',
    label: 'Products',
    title: 'Explore Our Vegetated Roof Systems',
    description: 'Lush, fully vegetated LiveRoof modules designed for instant maturity and lasting performance.',
    linkText: 'Learn More About Our Products',
    href: '#',
  },
  {
    img: '/images/wildflower-cityscape-1.jpg',
    label: 'LiveWall',
    title: 'Living Wall Systems',
    description: 'Complementary green wall solutions that bring vertical greenery to any building facade.',
    linkText: 'Learn More About LiveWall',
    href: '#',
  },
  {
    img: '/images/nursery-growing-field.jpeg',
    label: 'Hortech',
    title: 'Our Parent Company',
    description: 'One of the Midwest\'s leading wholesale growers of sustainably-grown perennials.',
    linkText: 'Learn More About Hortech',
    href: '#',
  },
];
---

<section class="py-14 md:py-24 bg-white">
  <div class="container">
    <div class="section-header">
      <span class="tag">Discover More</span>
      <h2>Part of the LiveRoof Family</h2>
      <p>Explore our full ecosystem of vegetated roof products, living walls, and sustainably-grown plants.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
      {cards.map((card) => (
        <a href={card.href} class="benefit-card group">
          <div class="aspect-[16/10] overflow-hidden">
            <img src={card.img} alt={card.label} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-6">
            <span class="tag">{card.label}</span>
            <h3 class="font-serif text-[1.3rem] text-dark mb-2">{card.title}</h3>
            <p class="text-[0.9rem] text-text-muted leading-relaxed">{card.description}</p>
            <span class="benefit-link mt-4">
              {card.linkText}
              <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
