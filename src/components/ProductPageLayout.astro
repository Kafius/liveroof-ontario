---
interface Props {
  name: string;
  tagline: string;
  img: string;
}

const { name, tagline, img } = Astro.props;
---

<section class="py-24 bg-white">
  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <!-- Product Image -->
      <div class="lg:sticky lg:top-[100px]">
        <div class="rounded-xl overflow-hidden aspect-[4/3]">
          <img src={img} alt={name} class="w-full h-full object-cover" />
        </div>
        <p class="text-sm text-text-muted mt-4 italic">{tagline}</p>
      </div>

      <!-- Product Content -->
      <div>
        <slot />
      </div>
    </div>
  </div>
</section>
