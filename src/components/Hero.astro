---

<section class="hero">
  <div class="hero-video-wrap">
    <video autoplay muted loop playsinline>
      <source src="/images/media1.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="hero-overlay"></div>
  <div class="container hero-container">
    <div class="hero-content">
      <div class="hero-eyebrow">LiveRoof Vegetated Roof Systems</div>
      <h1>The Proof is in the Roof</h1>
      <p class="hero-sub">
        Natural stormwater management from your local nursery.<br />
        LiveRoof modular vegetated roof design delivers lasting performance and natural beauty from Day One.
      </p>
      <div class="flex gap-3.5 flex-wrap">
        <a href="/products" class="btn btn-primary">Explore Products</a>
        <a href="/portfolio" class="btn btn-outline">View Portfolio</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-video-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .hero-video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
</style>
