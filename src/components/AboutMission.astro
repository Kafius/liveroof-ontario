---
const sections = [
  {
    id: 'who-we-are',
    img: '/images/wildflower-cityscape-1.jpg',
    title: 'Who We Are',
    text: 'LiveRoof Ontario is the largest producer of pre-vegetated modular green roof systems in Canada. ',
    sub: 'From our nursery farm in southwestern Ontario, we have grown and delivered over 75 acres of vegetated roof modules to more than 900 projects throughout the region.',
  },
  {
    id: 'farm-to-rooftop',
    img: '/images/installation-crane-closeup.jpeg',
    title: 'From Farm to Rooftop',
    text: 'The vegetated roof modules are grown in our nursery fields. Over the years we have developed systems to mechanize the different steps of the production and harvesting process. From mixing the growing medium and filling up the modules with growing medium and plants at the start, to harvesting the full-grown modules from the fields and loading them into our customs racks in time for installation. ',
    sub: 'All without serious physical effort on the part of our employees.  We utilise special trailers drawn by our own trucks and company drivers to make lifting and installation as safe and efficient as possible.',
  },
  {
    id: 'expertise',
    img: '/images/coneflower-meadow-roof.jpeg',
    title: 'Expertise',
    text: 'As Canada’s largest producer of pre-vegetated modular green roof systems, we carry a local expertise gained over decades in the horticultural and vegetated roof industries. ',
    sub: 'Growing and delivering the best solutions for any vegetated roof project, considering the requirements and priorities of each case. We can guide you through the best solutions to address stormwater management, ease of maintenance and beautification.',
  },
];
---

<section class="py-14 md:py-24 bg-white">
  <div class="container">
    <div class="grid gap-14 md:gap-20">
      {sections.map((s, i) => (
        <div id={s.id} class={`scroll-mt-28 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center ${i % 2 === 1 ? 'md:[direction:rtl]' : ''}`}>
          <div class={`rounded-xl overflow-hidden aspect-[4/3] ${i % 2 === 1 ? 'md:[direction:ltr]' : ''}`}>
            <img src={s.img} alt={s.title} class="w-full h-full object-cover" />
          </div>

          <div class={`${i % 2 === 1 ? 'md:[direction:ltr]' : ''}`}>
            <h2 class="font-serif text-[2.2rem] leading-[1.18] text-dark mb-5">{s.title}</h2>
            <p class="text-base text-text-muted leading-[1.75] mb-4">{s.text}</p>
            {s.sub && <p class="text-base text-text-muted leading-[1.75] mb-4">{s.sub}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
