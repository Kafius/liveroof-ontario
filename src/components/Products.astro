---
const products = [
  { title: 'Vegetative Roof Modules', desc: 'Pre-grown, plug-and-play modules for instant roof coverage.', href: '/products/modules', img: '/images/index-modules.webp' },
  { title: 'RoofEdge', desc: 'Aluminum edging for clean, secure perimeter details.', href: '/products/roofedge', img: '/images/roofedge.jpg' },
  { title: 'RoofStone', desc: 'Concrete pavers proven to reduce runoff by 25%.', href: '/products/roofstone', img: '/images/roofstone-pavers.png' },
  { title: 'WindDisc', desc: 'Ballast system engineered for high-wind zones.', href: '/products/winddisc', img: '/images/index-modules.webp' },
  { title: 'RoofBlue', desc: 'Blue-green water retention layer for enhanced performance.', href: '/products/roofblue', img: '/images/roofblue.jpg' },
  { title: 'RoofTop Proven™ Plants', desc: 'Rigorously tested exclusive plant selections for vegetative roofs.', href: '/products/plants', img: '/images/plants.jpg' },
  { title: 'Engineered Soil', desc: 'Locally blended growing media for optimal plant health.', href: '/products/soil', img: '/images/soil.jpg' },
  { title: 'SolaGreen™', desc: 'Integrated solar + vegetative roof system for 2025 and beyond.', href: '/products', img: '/images/solagreen.webp' },
  { title: 'Hydropavers', desc: 'Permeable paving solution that manages stormwater while supporting foot traffic.', href: '/products/hydropavers', img: '/images/roofstone-pavers.png' },
];
---

<section class="bg-dark py-14 md:py-24">
  <div class="container">
    <div class="section-header">
      <span class="tag" style="color:#17b060">Full Product Line</span>
      <h2 class="!text-white">Everything Your Roof Needs</h2>
      <p class="!text-white/[0.55]">
        From modules to accessories, every LiveRoof component is engineered for decades of
        performance.
      </p>
    </div>
    <div class="products-grid">
      {products.map((p) => (
        <a href={p.href} class="product-card">
          <div class="h-40 overflow-hidden">
            <img src={p.img} alt={p.title} class="w-full h-full object-cover" />
          </div>
          <div class="product-card-body p-5">
            <h4>{p.title}</h4>
            <p>{p.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
