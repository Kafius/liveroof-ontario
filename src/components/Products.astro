---
import PhotoPlaceholder from './PhotoPlaceholder.astro';

const products = [
  { title: 'Green Roof Modules', desc: 'Pre-grown, plug-and-play modules for instant roof coverage.' },
  { title: 'RoofEdge', desc: 'Aluminum edging for clean, secure perimeter details.' },
  { title: 'RoofStone', desc: 'Concrete pavers proven to reduce runoff by 25%.' },
  { title: 'WindDisc', desc: 'Ballast system engineered for high-wind zones.' },
  { title: 'RoofBlue', desc: 'Blue-green water retention layer for enhanced performance.' },
  { title: 'RoofTop Proven™ Plants', desc: 'Rigorously tested exclusive plant selections for green roofs.' },
  { title: 'Engineered Soil', desc: 'Locally blended growing media for optimal plant health.' },
  { title: 'SolaGreen™', desc: 'Integrated solar + green roof system for 2025 and beyond.' },
];
---

<section class="bg-dark py-14 md:py-24">
  <div class="container">
    <div class="section-header">
      <span class="tag" style="color:#00B25A">Full Product Line</span>
      <h2 class="!text-white">Everything Your Roof Needs</h2>
      <p class="!text-white/[0.55]">
        From modules to accessories, every LiveRoof component is engineered for decades of
        performance.
      </p>
    </div>
    <div class="products-grid">
      {products.map((p) => (
        <div class="product-card">
          <div class="h-40">
            <PhotoPlaceholder
              label="Photo"
              class="h-full"
              style="background: linear-gradient(135deg, #0d2f20 0%, #0a2d3f 100%); color: rgba(255,255,255,0.25);"
              showIcon={false}
            />
          </div>
          <div class="product-card-body p-5">
            <h4>{p.title}</h4>
            <p>{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
