---
import PhotoPlaceholder from './PhotoPlaceholder.astro';

const benefits = [
  {
    img: 'Colorful Green Roof Plantings',
    title: 'Natural Beauty',
    desc: "LiveRoof offers the natural function and beauty of built-in-place living roofs — without the extensive ongoing costs of maturation.",
  },
  {
    img: 'Installation Photo',
    title: 'Ease of Installation',
    desc: 'Enjoy the speed and convenience of modular delivery — without grid lines or compartmentalization of soil.',
  },
  {
    img: 'Mature Green Roof — Meijer Gardens',
    title: 'Instantly Mature',
    desc: 'Fully vegetated from Day One with a broader plant palette than carpet or mat systems — no establishment phase required.',
  },
];
---

<section class="bg-mid py-14 md:py-24">
  <div class="container">
    <div class="section-header">
      <span class="tag">Why LiveRoof?</span>
      <h2>Three Pillars of Performance</h2>
      <p>Our hybrid approach solves the core trade-offs that plague alternative green roof methods.</p>
    </div>
    <div class="benefits-grid">
      {benefits.map((b) => (
        <div class="benefit-card">
          <div class="h-[220px]">
            <PhotoPlaceholder label={b.img} class="h-full" />
          </div>
          <div class="benefit-body p-7">
            <h3>{b.title}</h3>
            <p>{b.desc}</p>
            <a href="/why-liveroof" class="benefit-link">Learn More →</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
