---
const projects = [
  { name: 'Haworth Corporate HQ', img: '/images/sedum-red-autumn.jpg' },
  { name: '215 N Peoria', img: '/images/wildflower-cityscape-2.jpg' },
  { name: 'Univ. of Notre Dame', img: '/images/historic-building-green-roof.jpeg' },
  { name: 'KLA', img: '/images/aerial-sedum-roof.jpeg' },
  { name: 'Waunakee Library', img: '/images/native-grass-roof.png' },
  { name: 'Union Station, Indianapolis', img: '/images/installation-crane-toronto.jpg' },
];
---

<section class="bg-mid py-14 md:py-24 overflow-hidden">
  <div class="container max-w-[1400px]">
    <div class="section-header">
      <span class="tag">Featured Projects</span>
      <h2>Thousands of Roofs. One Standard.</h2>
      <p>From university campuses to corporate headquarters, LiveRoof performs across every building type.</p>
    </div>
    <div class="portfolio-grid">
      {projects.map((p) => (
        <div class="port-item">
          <img src={p.img} alt={p.name} class="h-full w-full object-cover" />
        </div>
      ))}
    </div>
    <div class="text-center mt-9">
      <a href="/portfolio" class="btn btn-primary">Browse All Projects</a>
    </div>
  </div>
</section>
