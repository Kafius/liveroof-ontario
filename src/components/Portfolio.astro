---
const projects = [
  { name: 'CIBC Square', img: '/images/thou-of-roofs/CIBC_Square (2).jpeg' },
  { name: 'Fort York Library', img: '/images/thou-of-roofs/Fort York Library_0036 (2).JPG' },
  { name: "Frenchman's Bay Kiosk", img: "/images/thou-of-roofs/Frenchman's Bay Kiosk 3442 (2).JPG" },
  { name: 'GO Kipling Station', img: '/images/thou-of-roofs/Go Kipling Station 0910 e (2).JPG' },
  { name: "King's College, Western", img: "/images/thou-of-roofs/King's College Western (2).JPG" },
  { name: 'Old Post Office', img: '/images/thou-of-roofs/Old Post Office (2).JPG' },
];
---

<section class="bg-mid py-14 md:py-24 overflow-hidden">
  <div class="container max-w-[1400px]">
    <div class="section-header">
      <span class="tag">Featured Projects</span>
      <h2>Thousands of Roofs. One Standard.</h2>
      <p>From university campuses to corporate headquarters, LiveRoof performs across every building type.</p>
    </div>
    <div class="portfolio-grid">
      {projects.map((p) => (
        <div class="port-item">
          <img src={p.img} alt={p.name} class="h-full w-full object-cover" />
        </div>
      ))}
    </div>
    <div class="text-center mt-9">
      <a href="/portfolio" class="btn btn-primary">Browse All Projects</a>
    </div>
  </div>
</section>
