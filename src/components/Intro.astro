---
import PhotoPlaceholder from './PhotoPlaceholder.astro';
---

<section class="py-14 md:py-24">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-text">
        <span class="tag">Patented Hybrid Design</span>
        <h2>The <em>Best</em> of Both Worlds in Green Roofing</h2>
        <p>
          LiveRoof offers the natural function and <strong>natural beauty</strong> of built-in-place
          living roofs — without the extensive ongoing costs of maturation. It's the only system
          that delivers an instantly mature, fully vegetated green roof.
        </p>
        <p>
          Unlike conventional mat or carpet systems, LiveRoof modules arrive pre-grown,
          interconnected, and ready to thrive — eliminating the establishment phase that costs time
          and money.
        </p>
        <div class="flex gap-3.5 mt-8">
          <a href="#" class="btn btn-primary">Learn How It Works</a>
          <a href="#" class="btn-outline-dark btn">Design Guide ↗</a>
        </div>
      </div>
      <div class="rounded-xl overflow-hidden h-[280px] md:h-[440px]">
        <PhotoPlaceholder label="Product / Installation Photo" class="h-full" iconSize={40} />
      </div>
    </div>
  </div>
</section>
