---
interface Card {
  title: string;
  body: string;
}

interface Group {
  label?: string;
  cards: Card[];
}

interface Tab {
  id: string;
  label: string;
  subtitle: string;
  groups: Group[];
}

interface CardStyle {
  iconPath: string;
  color: string;
  bg: string;
}

function getCardStyle(title: string): CardStyle {
  const t = title.toLowerCase();
  if (/cost|save money|revenue|rental|income|financial|resale/.test(t))
    return { iconPath: 'M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6', color: '#16a34a', bg: '#dcfce7' };
  if (/energy|solar|ac cost|electric/.test(t))
    return { iconPath: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z', color: '#d97706', bg: '#fef3c7' };
  if (/storm|water|rain|retain|detain|cistern/.test(t))
    return { iconPath: 'M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z', color: '#0284c7', bg: '#e0f2fe' };
  if (/heal|health|wellness|patient|burnout|absentee/.test(t))
    return { iconPath: 'M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z', color: '#dc2626', bg: '#fee2e2' };
  if (/\broof\b|longev|warrant|module|membrane|edging|install/.test(t))
    return { iconPath: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z', color: '#17b060', bg: '#e6f7ee' };
  if (/fire|wind|uplift|ul |code|certif|complian|tested/.test(t))
    return { iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', color: '#6366f1', bg: '#eef2ff' };
  if (/employ|talent|recruit|attract|productiv|staff|retention/.test(t))
    return { iconPath: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z', color: '#7c3aed', bg: '#f5f3ff' };
  if (/habitat|natur|plant|garden|pollinator|beautif|transform|ugly|outdoor|teach|sustain|decompress/.test(t))
    return { iconPath: 'M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5zM16 8L2 22M17.5 15H9', color: '#059669', bg: '#d1fae5' };
  if (/brand|steward|goodwill|promote|mascot|identity|message|posterity|retrofit|show|progressive|walk|cause/.test(t))
    return { iconPath: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', color: '#0092CF', bg: '#e6f6fd' };
  return { iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z', color: '#17b060', bg: '#e6f7ee' };
}

