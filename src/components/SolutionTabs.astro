---

<!-- Tab Bar -->
<div class="sticky top-[76px] z-50 bg-dark border-b border-white/10 shadow-[0_4px_20px_rgba(0,0,0,0.15)]">
  <div class="container">
    <div
      class="flex gap-2 py-4 overflow-x-auto whitespace-nowrap solution-scrollbar"
      role="tablist"
      id="solution-tablist"
    >
      {tabs.map((tab, i) => (
        <button
          class={`solution-tab flex-shrink-0 px-5 py-2.5 rounded-md text-[0.82rem] font-semibold tracking-wide transition-all cursor-pointer border-2 ${
            i === 0
              ? 'bg-green text-white border-green shadow-[0_4px_16px_rgba(0,178,90,0.3)]'
              : 'bg-transparent text-white/60 border-white/10 hover:text-white hover:border-white/30'
          }`}
          data-tab={tab.id}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          tabindex={i === 0 ? '0' : '-1'}
        >
          {tab.label}
        </button>
      ))}
    </div>
  </div>
</div>

<!-- Tab Panels -->
{tabs.map((tab, i) => (
  <div
    class={`solution-panel ${i !== 0 ? 'hidden' : ''}`}
    data-panel={tab.id}
    role="tabpanel"
  >
    <div class="container py-14 md:py-20">
      <!-- Panel Header -->
      <div class="mb-10">
        <span class="tag">{tab.label}</span>
        <h2 class="font-serif text-[clamp(1.5rem,4vw,2.2rem)] text-dark leading-[1.18] mb-3">{tab.label}</h2>
        <p class="text-text-muted text-[0.95rem] max-w-[520px]">{tab.subtitle}</p>
      </div>

      {tab.groups.map((group) => (
        <div class="mb-10">
          {group.label && (
            <div class="flex items-center gap-3 mb-6">
              <div class="w-8 h-8 rounded-lg bg-blue-light flex items-center justify-center flex-shrink-0">
                <svg width="16" height="16" fill="none" stroke="#0092CF" stroke-width="2.5" viewBox="0 0 24 24">
                  <path d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-[0.72rem] font-bold tracking-[0.14em] uppercase text-blue">{group.label}</h3>
            </div>
          )}
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {group.cards.map((card) => (
              <div class="bg-white rounded-xl border border-border p-6 shadow-[0_2px_20px_rgba(35,31,32,0.06)] hover:-translate-y-1 hover:shadow-[0_10px_36px_rgba(35,31,32,0.1)] hover:border-green transition-all duration-200">
                <div class="flex items-start gap-3 mb-3">
                  <div class="w-8 h-8 rounded-lg bg-green-light flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg width="16" height="16" fill="none" stroke="#00B25A" stroke-width="2.5" viewBox="0 0 24 24">
                      <path d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <h4 class="font-serif text-[1.05rem] text-dark leading-snug">{card.title}</h4>
                </div>
                <p class="text-[0.88rem] text-text-muted leading-relaxed pl-11">{card.body}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
))}

<style>
  .solution-scrollbar::-webkit-scrollbar { height: 4px; }
  .solution-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .solution-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 4px; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tablist = document.getElementById('solution-tablist');
    if (!tablist) return;

    const allTabs = tablist.querySelectorAll<HTMLButtonElement>('.solution-tab');
    const allPanels = document.querySelectorAll<HTMLElement>('.solution-panel');

    function activate(tabId: string) {
      allTabs.forEach((t) => {
        const isActive = t.dataset.tab === tabId;
        // Active state
        t.classList.toggle('bg-green', isActive);
        t.classList.toggle('text-white', isActive);
        t.classList.toggle('border-green', isActive);
        t.classList.toggle('shadow-[0_4px_16px_rgba(0,178,90,0.3)]', isActive);
        // Inactive state
        t.classList.toggle('bg-transparent', !isActive);
        t.classList.toggle('text-white/60', !isActive);
        t.classList.toggle('border-white/10', !isActive);
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        t.tabIndex = isActive ? 0 : -1;
      });
      allPanels.forEach((p) => {
        p.classList.toggle('hidden', p.dataset.panel !== tabId);
      });
    }

    // Hash sync on load
    const hash = window.location.hash.replace('#', '');
    if (hash && document.querySelector(`[data-tab="${hash}"]`)) {
      activate(hash);
    }

    // Click handler
    allTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab!;
        activate(id);
        window.location.hash = id;
        const bar = tablist.closest('.sticky');
        if (bar) {
          const rect = bar.getBoundingClientRect();
          if (rect.top < 0) {
            bar.scrollIntoView({ behavior: 'smooth' });
          }
        }
      });
    });

    // Keyboard nav
    tablist.addEventListener('keydown', (e) => {
      const focused = document.activeElement as HTMLButtonElement;
      if (!focused?.classList.contains('solution-tab')) return;

      const tabArr = Array.from(allTabs);
      const idx = tabArr.indexOf(focused);
      let next = -1;

      if (e.key === 'ArrowRight') next = (idx + 1) % tabArr.length;
      else if (e.key === 'ArrowLeft') next = (idx - 1 + tabArr.length) % tabArr.length;

      if (next >= 0) {
        e.preventDefault();
        tabArr[next].focus();
        const id = tabArr[next].dataset.tab!;
        activate(id);
        window.location.hash = id;
      }
    });
  });
</script>
