<!-- Tab Bar -->
<div class="sticky top-[76px] z-50 bg-dark border-b border-white/10 shadow-[0_4px_20px_rgba(0,0,0,0.15)]">
  <div class="container">
    <div
      class="flex flex-wrap gap-2 py-4"
      role="tablist"
      id="solution-tablist"
    >
      {tabs.map((tab, i) => (
        <button
          class={`solution-tab px-5 py-2.5 rounded-md text-[0.82rem] font-semibold tracking-wide transition-all cursor-pointer border-2 ${
            i === 0
              ? 'bg-green text-white border-green shadow-[0_4px_16px_rgba(0,178,90,0.3)]'
              : 'bg-transparent text-white/60 border-white/10 hover:text-white hover:border-white/30'
          }`}
          data-tab={tab.id}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          tabindex={i === 0 ? '0' : '-1'}
        >
          {tab.label}
        </button>
      ))}
    </div>
  </div>
</div>

<!-- Tab Panels -->
{tabs.map((tab, i) => (
  <div
    class={`solution-panel ${i !== 0 ? 'hidden' : ''}`}
    data-panel={tab.id}
    role="tabpanel"
  >
    <div class="container py-14 md:py-20">

      <!-- Panel Header -->
      <div class="relative overflow-hidden rounded-2xl bg-dark mb-12 p-8 md:p-10">
        <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 85% 50%, rgba(0,178,90,0.18) 0%, transparent 60%)"></div>
        <div class="relative z-10">
          <span class="text-[0.68rem] font-bold tracking-[0.18em] uppercase text-green block mb-3">{tab.label}</span>
          <h2 class="font-serif text-[clamp(1.5rem,4vw,2.2rem)] text-white leading-[1.18] mb-0">{tab.subtitle}</h2>
          <div class="h-0.5 w-12 bg-green mt-5 rounded-full"></div>
        </div>
      </div>

      {tab.groups.map((group) => (
        <div class="mb-12">

          {group.label && (
            <div class="flex items-center gap-4 mb-7">
              <div class="h-px flex-1 bg-border"></div>
              <div class="flex items-center gap-2 bg-blue-light border border-blue/20 rounded-full px-4 py-1.5">
                <svg width="13" height="13" fill="none" stroke="#0092CF" stroke-width="2.5" viewBox="0 0 24 24">
                  <path d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-[0.68rem] font-bold tracking-[0.14em] uppercase text-blue">{group.label}</span>
              </div>
              <div class="h-px flex-1 bg-border"></div>
            </div>
          )}

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {group.cards.map((card, cardIdx) => {
              const s = getCardStyle(card.title);
              const isFeatured = !group.label && cardIdx === 0;

              return isFeatured ? (
                <div
                  class="col-span-full flex flex-col md:flex-row gap-7 items-start rounded-2xl p-8 md:p-10 border-2 shadow-md"
                  style={`background: ${s.bg}; border-color: ${s.color}30; border-top: 4px solid ${s.color}`}
                >
                  <div
                    class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0"
                    style={`background: ${s.color}`}
                  >
                    <svg width="26" height="26" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                      <path d={s.iconPath} />
                    </svg>
                  </div>
                  <div>
                    <div class="text-[0.68rem] font-bold tracking-[0.16em] uppercase mb-2" style={`color: ${s.color}`}>
                      Key Benefit
                    </div>
                    <h4 class="font-serif text-[1.35rem] text-dark leading-snug mb-3">{card.title}</h4>
                    <p class="text-[0.95rem] text-text-muted leading-relaxed max-w-prose">{card.body}</p>
                  </div>
                </div>
              ) : (
                <div
                  class="bg-white rounded-xl border border-border p-6 flex flex-col shadow-[0_2px_16px_rgba(35,31,32,0.06)] hover:-translate-y-1 hover:shadow-[0_10px_32px_rgba(35,31,32,0.1)] transition-all duration-200"
                  style={`border-top: 3px solid ${s.color}`}
                >
                  <div
                    class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 flex-shrink-0"
                    style={`background: ${s.bg}`}
                  >
                    <svg width="18" height="18" fill="none" stroke={s.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                      <path d={s.iconPath} />
                    </svg>
                  </div>
                  <h4 class="font-serif text-[1.05rem] text-dark leading-snug mb-2">{card.title}</h4>
                  <p class="text-[0.88rem] text-text-muted leading-relaxed flex-1">{card.body}</p>
                </div>
              );
            })}
          </div>
        </div>
      ))}

    </div>
  </div>
))}

<style></style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tablist = document.getElementById('solution-tablist');
    if (!tablist) return;

    const allTabs = tablist.querySelectorAll<HTMLButtonElement>('.solution-tab');
    const allPanels = document.querySelectorAll<HTMLElement>('.solution-panel');

    function activate(tabId: string) {
      allTabs.forEach((t) => {
        const isActive = t.dataset.tab === tabId;
        // Active state
        t.classList.toggle('bg-green', isActive);
        t.classList.toggle('text-white', isActive);
        t.classList.toggle('border-green', isActive);
        t.classList.toggle('shadow-[0_4px_16px_rgba(0,178,90,0.3)]', isActive);
        // Inactive state
        t.classList.toggle('bg-transparent', !isActive);
        t.classList.toggle('text-white/60', !isActive);
        t.classList.toggle('border-white/10', !isActive);
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        t.tabIndex = isActive ? 0 : -1;
      });
      allPanels.forEach((p) => {
        p.classList.toggle('hidden', p.dataset.panel !== tabId);
      });
    }

    // Hash sync on load
    const hash = window.location.hash.replace('#', '');
    if (hash && document.querySelector(`[data-tab="${hash}"]`)) {
      activate(hash);
    }

    // Click handler
    allTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab!;
        activate(id);
        window.location.hash = id;
        const bar = tablist.closest('.sticky');
        if (bar) {
          const rect = bar.getBoundingClientRect();
          if (rect.top < 0) {
            bar.scrollIntoView({ behavior: 'smooth' });
          }
        }
      });
    });

    // Keyboard nav
    tablist.addEventListener('keydown', (e) => {
      const focused = document.activeElement as HTMLButtonElement;
      if (!focused?.classList.contains('solution-tab')) return;

      const tabArr = Array.from(allTabs);
      const idx = tabArr.indexOf(focused);
      let next = -1;

      if (e.key === 'ArrowRight') next = (idx + 1) % tabArr.length;
      else if (e.key === 'ArrowLeft') next = (idx - 1 + tabArr.length) % tabArr.length;

      if (next >= 0) {
        e.preventDefault();
        tabArr[next].focus();
        const id = tabArr[next].dataset.tab!;
        activate(id);
        window.location.hash = id;
      }
    });
  });
</script>
