---
interface Props {
  name: string;
  tagline: string;
  description: string;
  href: string;
  chip?: string;
  chipColor?: 'green' | 'blue' | 'dark';
}

const { name, tagline, description, href, chip, chipColor = 'green' } = Astro.props;
---

<a href={href} class="group block bg-white rounded-xl border border-border overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_36px_rgba(35,31,32,0.1)] hover:border-blue">
  <div class="photo-placeholder aspect-[16/10]">
    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <rect x="3" y="3" width="18" height="18" rx="3" />
      <circle cx="8.5" cy="8.5" r="1.5" />
      <path d="m6 21 5.5-7 3.5 4 2.5-3L21 21" />
    </svg>
    <span>{name}</span>
  </div>
  <div class="p-6">
    {chip && <span class={`chip ${chipColor}`}>{chip}</span>}
    <h3 class="font-serif text-[1.3rem] text-dark mb-1">{name}</h3>
    <p class="text-[0.82rem] text-text-muted font-medium mb-2">{tagline}</p>
    <p class="text-[0.88rem] text-text-muted leading-relaxed mb-4">{description}</p>
    <span class="benefit-link">
      Learn More
      <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
    </span>
  </div>
</a>
