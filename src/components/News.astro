---
import PhotoPlaceholder from './PhotoPlaceholder.astro';

const articles = [
  {
    date: 'March 2025',
    title: 'The Science Behind LiveRoof — Energy Savings',
    desc: 'In an era of rising energy costs, LiveRoof green roof systems deliver measurable reductions in building energy consumption.',
  },
  {
    date: 'February 2025',
    title: 'Ronald McDonald House Green Roofs in Atlanta',
    desc: "Designed to last: the long-term performance of green roofs built to endure Georgia's climate for decades.",
  },
  {
    date: 'January 2025',
    title: 'Eight Years Later: LiveRoof Performance in Toronto',
    desc: "A case study from Bloor Islington Place, installed July 2018 — still thriving in one of Canada's most demanding urban climates.",
  },
];
---

<section class="py-14 md:py-24">
  <div class="container">
    <div class="section-header">
      <span class="tag">What's New</span>
      <h2>Latest from LiveRoof</h2>
      <p>Research, case studies, and insights from the world's leading green roof system.</p>
    </div>
    <div class="news-grid">
      {articles.map((a) => (
        <div class="news-card">
          <div class="h-[200px]">
            <PhotoPlaceholder label="Article Photo" class="h-full" iconSize={28} />
          </div>
          <div class="news-card-body p-6">
            <div class="news-date">{a.date}</div>
            <h4>{a.title}</h4>
            <p>{a.desc}</p>
            <a href="#" class="news-read">Read Article →</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
